    PlayerGroupAdd(lv_player[0], EventPlayer());
    if ((PlayerGetAlliance(gv_rTSPlayer1, c_allianceIdVision, EventPlayer()) == true)) {
        libNtve_gf_UnitCreateFacingPoint(1, "HydraliskHero", 0, EventPlayer(), PointFromId(1219627428), PlayerStartLocation(gv_rTSPlayer2));
        DialogSetVisible(gv_dialogTeam1, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    else {
        libNtve_gf_UnitCreateFacingPoint(1, "HydraliskHero", 0, EventPlayer(), PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer1));
        DialogSetVisible(gv_dialogTeam2, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_HydraliskPicked_Init () {
    gt_HydraliskPicked = TriggerCreate("gt_HydraliskPicked_Func");
    TriggerAddEventDialogControl(gt_HydraliskPicked, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Mutalisk Picked
//--------------------------------------------------------------------------------------------------
bool gt_MutaliskPicked_Func (bool testConds, bool runActions) {
    int init_i;

    // Variable Declarations
    playergroup[2] lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    for (init_i = 0; init_i <= 1; init_i += 1) {
        lv_player[init_i] = PlayerGroupEmpty();
    }

    // Conditions
    if (testConds) {
        if (!(((gv_mutaliskTeam1 == EventDialogControl()) || (gv_mutaliskTeam2 == EventDialogControl())))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(EventPlayer()) + StringExternal("Param/Value/CC8B1036")));
    PlayerGroupAdd(lv_player[0], EventPlayer());
    if ((PlayerGetAlliance(gv_rTSPlayer1, c_allianceIdVision, EventPlayer()) == true)) {
        libNtve_gf_UnitCreateFacingPoint(1, "MutaliskHero", 0, EventPlayer(), PointFromId(1219627428), PlayerStartLocation(gv_rTSPlayer2));
        DialogSetVisible(gv_dialogTeam1, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    else {
        libNtve_gf_UnitCreateFacingPoint(1, "MutaliskHero", 0, EventPlayer(), PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer1));
        DialogSetVisible(gv_dialogTeam2, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_MutaliskPicked_Init () {
    gt_MutaliskPicked = TriggerCreate("gt_MutaliskPicked_Func");
    TriggerAddEventDialogControl(gt_MutaliskPicked, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}

