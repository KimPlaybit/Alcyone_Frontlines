bool gt_WinTeam2_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_loopedPlayer;

    // Automatic Variable Declarations
    playergroup autoCC8E05C7_g;
    playergroup autoAB447701_g;

