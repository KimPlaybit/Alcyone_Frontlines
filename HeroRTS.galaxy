//--------------------------------------------------------------------------------------------------
// Trigger: Revive Heroes Team 1
//--------------------------------------------------------------------------------------------------
bool gt_ReviveHeroesTeam1_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_dyingUnit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_dyingUnit = EventUnit();

    // Conditions
    if (testConds) {
        if (!(((UnitTypeTestFlag(UnitGetType(lv_dyingUnit), c_unitFlagHero) == true) && (PlayerGroupHasPlayer(PlayerGroupAlliance(c_playerGroupAlly, gv_rTSPlayer1), UnitGetOwner(EventUnit())) == true)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(EventPlayer()) + (StringExternal("Param/Value/367A7D8C") + (UnitGetName(EventUnit()) + (StringExternal("Param/Value/7A34054A") + (PlayerName(libNtve_gf_KillingPlayer()) + StringExternal("Param/Value/3CB3AA14")))))));
    UnitSetState(lv_dyingUnit, c_unitStateHighlightable, false);
    UnitSetState(lv_dyingUnit, c_unitStateCursorable, false);
    UnitSetState(lv_dyingUnit, c_unitStateSelectable, false);
    UnitSetState(lv_dyingUnit, c_unitStateTooltipable, false);
    UnitSetState(lv_dyingUnit, c_unitStateStatusBar, false);
    UnitSetState(lv_dyingUnit, c_unitStateHidden, true);
    libNtve_gf_MakeUnitInvulnerable(lv_dyingUnit, true);
    UnitSetPosition(lv_dyingUnit, PointWithOffset(PointFromId(1219627428), 0.0, 3.0), false);
    UnitRevive(lv_dyingUnit);
    Wait(30.0, c_timeReal);
    libNtve_gf_MakeUnitInvulnerable(lv_dyingUnit, false);
    UnitSetState(lv_dyingUnit, c_unitStateHighlightable, true);
    UnitSetState(lv_dyingUnit, c_unitStateCursorable, true);
    UnitSetState(lv_dyingUnit, c_unitStateSelectable, true);
    UnitSetState(lv_dyingUnit, c_unitStateTooltipable, true);
    UnitSetState(lv_dyingUnit, c_unitStateStatusBar, true);
    UnitSetState(lv_dyingUnit, c_unitStateHidden, false);
    UnitSetPropertyFixed(lv_dyingUnit, c_unitPropLifePercent, 100.0);
    CameraPan(UnitGetOwner(lv_dyingUnit), PointFromId(1219627428), 0.0, -1, 10.0, false);
    UnitClearSelection(UnitGetOwner(lv_dyingUnit));
    UnitSelect(lv_dyingUnit, UnitGetOwner(lv_dyingUnit), true);
    return true;
}

