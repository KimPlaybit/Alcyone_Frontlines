//--------------------------------------------------------------------------------------------------
// Trigger: Setup Teams 1
//--------------------------------------------------------------------------------------------------
bool gt_SetupTeams1_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_loopedPlayer;

    // Automatic Variable Declarations
    playergroup autoD1CD5FB6_g;

    // Variable Initialization
    lv_loopedPlayer = 1;

    // Actions
    if (!runActions) {
        return true;
    }

    autoD1CD5FB6_g = gv_soldierPlayers1;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(autoD1CD5FB6_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        libNtve_gf_SetAlliance(lv_loopedPlayer, gv_rTSPlayer1, libNtve_ge_AllianceSetting_AllyWithSharedVision);
        CameraPan(lv_loopedPlayer, PointFromId(1219627428), 0.0, -1, 10.0, false);
    }
    return true;
}

