//--------------------------------------------------------------------------------------------------
// Trigger: Controller
//--------------------------------------------------------------------------------------------------
bool lib5A1C9904_gt_Controller_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_offsetVeterancy;
    unit lv_defendSpawner;
    point lv_startPos;
    point lv_hostilePoint;
    int lv_veteranLevel;
    int lv_player;
    unit lv_unit;
    unitgroup lv_unitGroup;
    int lv_state;
    point lv_currentPosition;
    point lv_lastPosition;
    int lv_stuckCounter;
    const int lv_maxCounter = 150;
    int lv_commit;
    int lv_allyRTSPlayer;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_veteranLevel = 1;
    lv_player = lib5A1C9904_gv_playerToStart;
    lv_unit = UnitGroupUnit(lib5A1C9904_gv_unitGroup, 1);
    lv_unitGroup = lib5A1C9904_gv_unitGroup;
    lv_state = 99;
    lv_allyRTSPlayer = lib5A1C9904_gf_GetAllyRTSPlayer(lv_player);

    // Actions
    if (!runActions) {
        return true;
    }

    lv_startPos = lib5A1C9904_gf_GetStartLocation(lv_allyRTSPlayer);
    AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
    AIAttackWaveSend(lv_player, 0, false);
    if (((UnitGetType(lv_unit) == "SpectreHero"))) {
        lv_offsetVeterancy = -2;
    }

    while (true) {
        lib5A1C9904_gf_HeroSpells(lv_player, lv_unit);
        lv_currentPosition = UnitGroupCenterOfGroup(lv_unitGroup);
        lv_veteranLevel = UnitXPGetCurrentLevel(lv_unit, null);
        lv_hostilePoint = lib5A1C9904_gf_AttackPointHostiles(lv_startPos, lv_currentPosition, lv_veteranLevel, lv_offsetVeterancy);
        if ((((lib5A1C9904_gf_IsProtoss(lv_allyRTSPlayer) == true) && (UnitGetPropertyFixed(lv_unit, c_unitPropShieldsPercent, c_unitPropCurrent) < 5.0)) || ((lib5A1C9904_gf_IsProtoss(lv_allyRTSPlayer) == false) && (UnitGetPropertyFixed(lv_unit, c_unitPropLifePercent, c_unitPropCurrent) < 30.0)) || ((lv_state == 1) && (UnitGetPropertyFixed(lv_unit, c_unitPropLifePercent, c_unitPropCurrent) < 70.0)) || ((lv_state == 1) && (UnitGetPropertyFixed(lv_unit, c_unitPropShieldsMax, c_unitPropCurrent) < 0.0) && (UnitGetPropertyFixed(lv_unit, c_unitPropShieldsPercent, c_unitPropCurrent) < 50.0)))) {
            if ((lv_state != 1)) {
                AISetDifficulty(lv_player, c_diffNormalTargetPrio, true);
                AISetDifficulty(lv_player, c_diffWaveLeashing, true);
                AISetDifficulty(lv_player, c_diffWaveAvoidDanger, true);
                AIAttackWaveSetTargetPoint(lv_player, lv_startPos);
                AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                AIAttackWaveSend(lv_player, 0, false);
                UnitIssueOrder(lv_unit, OrderTargetingPoint(AbilityCommand("move", 0), UnitGetPosition(lib5A1C9904_gf_FindHealspot(lv_unit))), c_orderQueueReplace);
                lv_state = 1;
                lv_stuckCounter = 0;
            }
            else {
                if ((lv_stuckCounter >= lv_maxCounter)) {
                    lv_state = 99;
                    lv_lastPosition = null;
                    lv_stuckCounter = 0;
                }
                else {
                    if ((((lib5A1C9904_gf_IsProtoss(lv_allyRTSPlayer) == true) && (UnitGetPropertyFixed(lv_unit, c_unitPropShieldsPercent, c_unitPropCurrent) >= 70.0)) || ((lib5A1C9904_gf_IsProtoss(lv_allyRTSPlayer) == false)))) {
                        lv_stuckCounter = (lv_stuckCounter + 1);
                    }

                }
            }
        }
        else {
            lv_defendSpawner = lib5A1C9904_gf_SpawnersBeingAttacked(lv_unit, lv_player);
            if (((lv_defendSpawner != null))) {
                if ((lv_state != 3)) {
                    AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                    AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                    AIAttackWaveSetTargetRegion(lv_player, RegionCircle(UnitGetPosition(lv_unit), 3.0), 1);
                    AISetDifficulty(lv_player, c_diffNormalTargetPrio, false);
                    AISetDifficulty(lv_player, c_diffWaveLeashing, false);
                    AISetDifficulty(lv_player, c_diffWaveAvoidDanger, false);
                    libNtve_gf_AICast(lv_unit, OrderTargetingPoint(AbilityCommand("move", 0), UnitGetPosition(lv_defendSpawner)));
                    AIAttackWaveSend(lv_player, 0, false);
                    lv_lastPosition = lv_hostilePoint;
                    lv_stuckCounter = 0;
                    lv_state = 3;
                    if ((UnitGetType(lv_unit) == "DragoonHero")) {
                        UnitIssueOrder(lv_unit, OrderTargetingUnit(AbilityCommand("ArtanisWormholeTransit", 0), lv_defendSpawner), c_orderQueueReplace);
                        UnitIssueOrder(lv_unit, OrderTargetingPoint(AbilityCommand("SJCloakedMineAttack", 0), UnitGetPosition(lv_defendSpawner)), c_orderQueueAddToEnd);
                    }

                }
                else {
                    if ((lv_stuckCounter >= lv_maxCounter)) {
                        lv_state = 99;
                        lv_lastPosition = null;
                        lv_stuckCounter = 0;
                    }
                    else {
                        lv_stuckCounter = (lv_stuckCounter + 1);
                    }
                }
            }
            else {
                if ((lv_hostilePoint != null)) {
                    if ((((lv_lastPosition == null) || (DistanceBetweenPoints(lv_lastPosition, lv_hostilePoint) >= 5.0))) && (lv_state != 2)) {
                        if ((((lib5A1C9904_gf_IsProtoss(lv_allyRTSPlayer) == true) && (UnitGetPropertyFixed(lv_unit, c_unitPropShieldsPercent, c_unitPropCurrent) > 30.0)) || ((lib5A1C9904_gf_IsProtoss(lv_allyRTSPlayer) == false)))) {
                            AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                            AISetDifficulty(lv_player, c_diffNormalTargetPrio, true);
                            AISetDifficulty(lv_player, c_diffWaveLeashing, true);
                            AISetDifficulty(lv_player, c_diffWaveAvoidDanger, true);
                            AIAttackWaveSetTargetUnitGroup(lv_player, UnitGroup(null, 15, RegionCircle(lv_hostilePoint, 5.0), UnitFilter(0, 0, (1 << c_targetFilterPlayer) | (1 << c_targetFilterAlly) | (1 << c_targetFilterNeutral) | (1 << c_targetFilterStructure) | (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0));
                            AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                            AIAttackWaveSend(lv_player, 0, false);
                            lv_lastPosition = lv_hostilePoint;
                            lv_stuckCounter = 0;
                            lv_state = 2;
                        }
                        else {
                            AISetDifficulty(lv_player, c_diffNormalTargetPrio, true);
                            AISetDifficulty(lv_player, c_diffWaveLeashing, true);
                            AISetDifficulty(lv_player, c_diffWaveAvoidDanger, true);
                            AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                            AIAttackWaveSetTargetPoint(lv_player, lv_startPos);
                            AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                            AIAttackWaveSend(lv_player, 0, false);
                            UnitIssueOrder(lv_unit, OrderTargetingPoint(AbilityCommand("move", 0), UnitGetPosition(lib5A1C9904_gf_FindHealspot(lv_unit))), c_orderQueueReplace);
                            lv_state = 2;
                        }
                    }
                    else {
                        if ((lv_stuckCounter >= lv_maxCounter)) {
                            lv_state = 99;
                            lv_lastPosition = null;
                            lv_stuckCounter = 0;
                        }
                        else {
                            lv_stuckCounter = (lv_stuckCounter + 1);
                        }
                    }
                }
                else {
                    if ((lv_state != 0)) {
                        AISetDifficulty(lv_player, c_diffNormalTargetPrio, true);
                        AISetDifficulty(lv_player, c_diffWaveLeashing, true);
                        AISetDifficulty(lv_player, c_diffWaveAvoidDanger, true);
                        AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                        if (((UnitGetType(lv_unit) == "ZerglingHero") || (UnitGetType(lv_unit) == "AvengerHero") || (UnitGetType(lv_unit) == "SpectreHero"))) {
                            AIAttackWaveSetTargetUnitGroup(lv_player, UnitGroupAlliance(lib5A1C9904_gf_GetEnemyRTSPlayer(lv_player), c_unitAllianceAllyExcludeSelf, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterPlayer) | (1 << c_targetFilterNeutral) | (1 << c_targetFilterEnemy) | (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0));
                        }
                        else {
                            AIAttackWaveSetTargetUnitGroup(lv_player, UnitGroupAlliance(lib5A1C9904_gf_GetEnemyRTSPlayer(lv_player), c_unitAllianceAlly, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterEnemy) | (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0));
                        }
                        AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                        AIAttackWaveSend(lv_player, 0, false);
                        lv_state = 0;
                        lv_stuckCounter = 0;
                    }
                    else {
                        if ((lv_stuckCounter >= lv_maxCounter)) {
                            lv_state = 99;
                            lv_lastPosition = null;
                            lv_stuckCounter = 0;
                        }
                        else {
                            lv_stuckCounter = (lv_stuckCounter + 1);
                        }
                    }
                }
            }
        }
        Wait(0.1, c_timeGame);
    }
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/lib_5A1C9904_7E009E82")));
    return true;
}

