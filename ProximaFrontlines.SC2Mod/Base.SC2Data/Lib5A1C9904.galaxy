void lib5A1C9904_gf_StartAi (point lp_startPos, int lp_player) {
    // Automatic Variable Declarations
    // Implementation
        int diff = AIPlayerDifficulty(lp_player);
        point targDPoint;
        point targOPoint;
        wavetarget targD;
        wavetarget targO;
        int attackersLimit;
    if ((PlayerType(lp_player) == c_playerTypeComputer)) {
        	AIStart(lp_player, false, DifficultyAPM(diff));
            if (diff == c_skirChInsane) {
                // insane starts at 1.2 and ramps to 2.0
                AIHarvestBonus(lp_player, 1.2);
            }
            
            AISetDifficulty(lp_player, c_diffRepairDamage, true);
            AISetDifficulty(lp_player, c_diffOptimizeGas, true);
            AISetDifficulty(lp_player, c_diffDefendWithPeons, false);
            AISetDifficulty(lp_player, c_diffEnableDangerMap, true);
            AISetDifficulty(lp_player, c_diffNormalTargetPrio, true);
            AISetDifficulty(lp_player, c_diffAllowResourceReq, true);
            AISetDifficulty(lp_player, c_diffAdvancedRetreatLogic, true);
            AISetDifficulty(lp_player, c_diffSupportsBeacons, true);
            AISetDifficulty(lp_player, c_diffAutoBuildPrereqs, true);
            AISetDifficulty(lp_player, c_diffAllowBuildInDanger, true);
            AISetDifficulty(lp_player, c_diffTimeoutMakeRequests, true);
            AISetDifficulty(lp_player, c_diffSetRallyPoints, true);
            AISetDifficulty(lp_player, c_diffAllowLongDistanceMining, true);
            AISetDifficulty(lp_player, c_diffBalancePeonsAcrossBases, true);
            AISetDifficulty(lp_player, c_diffWaveLeashing, true);
            AISetDifficulty(lp_player, c_diffAutoTransport, true);
            AISetDifficulty(lp_player, c_diffAllowTransportGather, true);
            AISetDifficulty(lp_player, c_diffAvoidMindControlled, true);
            AISetDifficulty(lp_player, c_diffNormalVision,     (diff < c_skirChVision));       // normal vision, unless cheating
            AISetDifficulty(lp_player, c_diffLimitAPM,         (diff < c_skirHard_VH));        // limit all apm on lower difficulties
            AISetDifficulty(lp_player, c_diffLimitAPMCombat,   (diff < c_skirVeryHard));       // limit combat apm below elite
            AISetDifficulty(lp_player, c_diffSplitAttacking,   (diff < c_skirVeryHard));       // split attacks below elite
            AISetDifficulty(lp_player, c_diffSpotChangelings,   (diff >= c_skirVeryHard));
            AISetDifficulty(lp_player, c_diffWaveAvoidDanger,   (diff >= c_skirHard));
            AISetDifficulty(lp_player, c_diffEarlyDefenseScout, (diff >= c_skirHard));
            AISetDifficulty(lp_player, c_diffUseExtraScouts,    (diff >= c_skirHard));
            AISetDifficulty(lp_player, c_diffHoldAtIdleChokes,  (diff >= c_skirHard));
            AISetDifficulty(lp_player, c_diffPressForward,      (diff >= c_skirMedium));
            AISetDifficulty(lp_player, c_diffFleeWorkers,       (diff >= c_skirMedium));
            AISetDifficulty(lp_player, c_diffFleeDanger,        (diff >= c_skirMedium));
            AISetDifficulty(lp_player, c_diffTargetSpawners,    (diff >= c_skirMedium));
            AISetDifficulty(lp_player, c_diffAllowKiting,       (diff >= c_skirHard_VH));
            AISetDifficulty(lp_player, c_diffDelayAdvTargetting,(diff <= c_skirMedium));       // deliberately target interceptors/locusts on medium and below
            AISetDifficulty(lp_player, c_diffAutoLoadBunkers, false);
            AISetDifficulty(lp_player, c_diffEarlyGameRepair, false);
            AISetFlag(lp_player, e_flagsAllowRetreat, (diff >= c_skirMed_Hard));
            AISetFlag(lp_player, e_flagsAllowDropAttack, (diff >= c_skirChMoney));     // only going to allow resource cheating AIs to drop, it's rarely successful and often costs resources
            AISetFlag(lp_player, e_flagsRunScared, false);
            AISetFlag(lp_player, e_flagsLateScout, false);
            AISetFlag(lp_player, e_flagsClearObs, false);
            AIDeclareTown(lp_player, c_townOne, lp_startPos);
            AISetMainTown(lp_player, c_townOne);
            AIHarvest(lp_player, c_townOne);
            AISetAllStates(lp_player, 1);
            
            targDPoint = AIWaveTargetGatherDPoint(lp_player, c_townMain);
            targOPoint = AIWaveTargetGatherOPoint(lp_player, c_townMain);
            targD = AIWaveTargetGatherD(lp_player, c_townMain);
            targO = AIWaveTargetGatherMelee(lp_player);    
            AIWaveSet(lp_player, c_waveMain,       AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveAttack,     AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveDivert1,    AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveDivert2,    AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveClearObs,   AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveHome,       AIWaveCreate(AIWaveInfoCreate(), lp_player, targDPoint));
            AIWaveSet(lp_player, c_waveDefend,     AIWaveCreate(AIWaveInfoCreate(), lp_player, targDPoint));
            AIWaveSetType(AIWaveGet(lp_player, c_waveMain),     c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveAttack),   c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveDivert1),  c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveDivert2),  c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveClearObs), c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveHome),     c_waveStateIdle, targD);
            AIWaveSetType(AIWaveGet(lp_player, c_waveDefend),   c_waveStateIdle, targD);
            attackersLimit = 1 << diff;
            AISetMaxBestAttackersLimit(lp_player, attackersLimit);
            AITransportIgnore(lp_player, "VikingAssault");
            AITransportSetPanic(lp_player, 0.6);
            AITransportSetReturn(lp_player, targDPoint);
            AISetDefenseRadii(lp_player, 15.0, 10.0, 12.0);
            AISetNumScouts(lp_player, 1);
            AIEarlyDefenseEnable(lp_player, false, false);
            if (diff < c_skirChVision) {
                // need early defense scouting if not cheating vision
                AIEarlyDefenseProps(lp_player, 30, 20, 30);
            } else {
                // let cheating AIs defend against further threats
                AIEarlyDefenseProps(lp_player, 35, 35, 45);
                if (!AIHasHumanAlly(lp_player)) {
                    AISetNumScouts(lp_player, 0);
                }
            }
            AIScout(lp_player);
            AISetUserInt(lp_player, c_numGroundStartLocs, AIGetGroundStartLocs(lp_startPos));
            AISetUserInt(lp_player, c_numAirStartLocs, AIGetAirStartLocs(lp_startPos));
            AISetUserInt(lp_player, c_delayNextAttack, 0);
            AISpecifiedHealers(lp_player);
            AISetDefaultCombatFlags(lp_player, true);
    }

}

void lib5A1C9904_gf_StartSoldierAI (point lp_startPos, int lp_player, unit lp_wave) {
    // Variable Declarations
    wavetarget lv_targO;
    wavetarget lv_targD;
    point lv_targOPoint;
    point lv_targDPoint;
    int lv_diff;
    waveinfo lv_heroWave;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_heroWave = AIWaveInfoCreate();

    // Implementation
    AIStart(lp_player, true, 200);
    AISetDifficulty(lp_player, c_diffEnableDangerMap, true);
    AISetDifficulty(lp_player, c_diffNormalTargetPrio, true);
    AISetDifficulty(lp_player, c_diffWaveLeashing, true);
    AISetDifficulty(lp_player, c_diffWaveAvoidDanger, true);
    AISetDifficulty(lp_player, c_diffSplitAttacking, true);
    AISetDifficulty(lp_player, c_diffFleeDamage, true);
    AISetDifficulty(lp_player, c_diffHoldAtIdleChokes, true);
    AISetDifficulty(lp_player, c_diffAllowKiting, true);
    AISetDifficulty(lp_player, c_diffAdvancedRetreatLogic, true);
    AISetFlag(lp_player, e_flagsAllowRetreat, true);
    AIEarlyDefenseEnable(lp_player, true, true);
    AIReqCountAsBuiltObject(lp_player, UnitGetType(lp_wave));
    AIAttackWaveUseUnit(lp_player, lp_wave);
    AIEvalSetCustomIndex((10 + (UnitXPGetCurrentLevel(lp_wave, null) * 3)));
    AIDeclareTown(lp_player, -1, lp_startPos);
    lib5A1C9904_gv_playerToStart = lp_player;
    lib5A1C9904_gv_unitGroup = libNtve_gf_ConvertUnitToUnitGroup(lp_wave);
    TriggerExecute(lib5A1C9904_gt_Controller, false, false);
}

