unit lib5A1C9904_gf_SpawnersBeingAttacked (unit lp_heroUnit, int lp_player) {
    // Variable Declarations
    unit lv_unit;
    unit lv_spawner;
    unitgroup lv_spawners;

    // Automatic Variable Declarations
    unitgroup auto48514808_g;
