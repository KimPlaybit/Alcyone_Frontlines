//--------------------------------------------------------------------------------------------------
// Trigger: AIBuildShieldBattery
//--------------------------------------------------------------------------------------------------
bool lib5A1C9904_gt_AIBuildShieldBattery_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_player = UnitGetOwner(EventUnit());

    // Conditions
    if (testConds) {
        if (!(((PlayerType(lv_player) == c_playerTypeComputer) && (UnitGetType(EventUnitCreatedUnit()) == "CyberneticsCore")))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
