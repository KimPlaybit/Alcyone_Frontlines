        }

    }
    auto6DA5227F_g = lv_allStructuresAround;
    auto6DA5227F_u = UnitGroupCount(auto6DA5227F_g, c_unitCountAll);
    for (;; auto6DA5227F_u -= 1) {
        lv_unit = UnitGroupUnitFromEnd(auto6DA5227F_g, auto6DA5227F_u);
        if (lv_unit == null) { break; }
        UnitKill(lv_unit);
    }
    auto9B5F1820_g = lv_allWorkersAround;
    auto9B5F1820_u = UnitGroupCount(auto9B5F1820_g, c_unitCountAll);
