    if (!runActions) {
        return true;
    }

    lv_unitIndex = 0;
    for ( ; ( (autoFF7A1BDD_ai >= 0 && lv_unitIndex <= autoFF7A1BDD_ae) || (autoFF7A1BDD_ai < 0 && lv_unitIndex >= autoFF7A1BDD_ae) ) ; lv_unitIndex += autoFF7A1BDD_ai ) {
        if ((gv_bases[lv_unitIndex] == lv_deadUnit)) {
