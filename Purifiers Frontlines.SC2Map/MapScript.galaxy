    lv_baseSpawn = gf_GetDefaultExpansionBase(gf_GetAlly(lv_killedPlayer, lv_killingPlayer));
    lv_workerSpawn = gf_GetDefaultExpansionWorker(gf_GetAlly(lv_killedPlayer, lv_killingPlayer));

