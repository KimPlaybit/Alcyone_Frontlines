        <Name>StartAi</Name>
        <FlagAction/>
        <Parameter Type="ParamDef" Id="54FBAC59"/>
        <Parameter Type="ParamDef" Id="BB7CB9B7"/>
        <FunctionCall Type="FunctionCall" Id="20A2F3CE"/>
