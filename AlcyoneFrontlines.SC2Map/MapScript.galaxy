// Trigger: Increase RessTimer
//--------------------------------------------------------------------------------------------------
bool gt_IncreaseRessTimer_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    gv_ressTimer = 20;
    Wait(120.0, c_timeReal);
    gv_ressTimer = 30;
    Wait(360.0, c_timeReal);
    gv_ressTimer = 40;
    Wait(600.0, c_timeReal);
    gv_ressTimer = 50;
    return true;
}

