//--------------------------------------------------------------------------------------------------
// Trigger: ZerglingMineExplodes
//--------------------------------------------------------------------------------------------------
bool lib1_gt_ZerglingMineExplodes_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_unitsDmg;
    int lv_unitsShield;
    int lv_unitsHealth;
    int lv_quadHealth;
    int lv_quadShield;
    int lv_totalDmg;
    unit lv_damagingUnit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unitsDmg = 75;
    lv_unitsShield = UnitGetPropertyInt(EventUnit(), c_unitPropShieldsMax, c_unitPropCurrent);
    lv_unitsHealth = UnitGetPropertyInt(EventUnit(), c_unitPropLifeMax, c_unitPropCurrent);
    lv_quadHealth = (lv_unitsHealth / 4);
    lv_quadShield = (lv_unitsShield / 4);
    lv_totalDmg = ((lv_quadHealth + lv_quadShield) + lv_unitsDmg);
    lv_damagingUnit = EventUnitDamageSourceUnit();

    // Conditions
    if (testConds) {
        if (!((UnitGetType(EventUnitDamageSourceUnit()) == "HotSRaptorBurrowed"))) {
            return false;
        }

        if (!((UnitTypeTestAttribute(UnitGetType(EventUnit()), c_unitAttributeStructure) == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitDamage(lv_damagingUnit, "HotSBanelingExplodeLargeSearchDamage2", EventUnit(), lv_totalDmg);
    return true;
}

