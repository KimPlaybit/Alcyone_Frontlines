    if (testConds) {
        if (!(((UnitGetOwner(EventUnitCreatedUnit()) == lib1_gv_rTSPlayer1) && (UnitTypeTestAttribute(UnitGetType(EventUnitCreatedUnit()), c_unitAttributeStructure) == true)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitGroupAdd(lib1_gv_rtsPlayer1Buildings, EventUnitCreatedUnit());
    if (((UnitGetType(EventUnitCreatedUnit()) == "Nexus") || (UnitGetType(EventUnitCreatedUnit()) == "Hive") || (UnitGetType(EventUnitCreatedUnit()) == "Lair") || (UnitGetType(EventUnitCreatedUnit()) == "Hatchery") || (UnitGetType(EventUnitCreatedUnit()) == "CommandCenter") || (UnitGetType(EventUnitCreatedUnit()) == "OrbitalCommand") || (UnitGetType(EventUnitCreatedUnit()) == "PlanetaryFortress"))) {
        UnitGroupAdd(lib1_gv_rtsPlayer1TownBuilding, EventUnitCreatedUnit());
    }

    return true;
}

