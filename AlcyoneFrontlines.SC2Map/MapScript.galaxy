void lib1_gf_SetupTeams1 () {
    // Variable Declarations
    int lv_loopedPlayer;
    int lv_loopedPlayer2;

    // Automatic Variable Declarations
    playergroup auto99AFCEBA_g;
    playergroup autoFC3B8092_g;

    // Variable Initialization
    lv_loopedPlayer = 1;
    lv_loopedPlayer2 = 1;

    // Implementation
    libNtve_gf_SetAlliance(13, lib1_gv_rTSPlayer1, libNtve_ge_AllianceSetting_NeutralWithSharedVision);
    libNtve_gf_SetAlliance(14, lib1_gv_rTSPlayer1, libNtve_ge_AllianceSetting_Enemy);
    auto99AFCEBA_g = lib1_gv_soldierPlayers1;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(auto99AFCEBA_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        libNtve_gf_SetAlliance(lv_loopedPlayer, lib1_gv_rTSPlayer1, libNtve_ge_AllianceSetting_AllyWithSharedVision);
        autoFC3B8092_g = lib1_gv_soldierPlayers1;
        lv_loopedPlayer2 = -1;
        while (true) {
            lv_loopedPlayer2 = PlayerGroupNextPlayer(autoFC3B8092_g, lv_loopedPlayer2);
            if (lv_loopedPlayer2 < 0) { break; }
            libNtve_gf_SetAlliance(lv_loopedPlayer, lv_loopedPlayer2, libNtve_ge_AllianceSetting_AllyWithSharedVision);
        }
        libNtve_gf_SetAlliance(13, lv_loopedPlayer, libNtve_ge_AllianceSetting_NeutralWithSharedVision);
        libNtve_gf_SetAlliance(14, lv_loopedPlayer, libNtve_ge_AllianceSetting_Enemy);
        CameraPan(lv_loopedPlayer, PointFromId(1219627428), 0.0, -1, 10.0, false);
    }
}

