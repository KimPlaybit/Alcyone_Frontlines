    else {
        UnitSetOwner(lv_tower, 13, true);
    }
    UnitIssueOrder(lv_tower, OrderTargetingUnit(AbilityCommand("TowerCapture", 0), lv_tower), c_orderQueueReplace);
    Wait(180.0, c_timeGame);
    UnitSetOwner(lv_tower, 0, true);
    UnitSetState(lv_tower, c_unitStateSilenced, true);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_ActivateXelNagaTower3_Init () {
    gt_ActivateXelNagaTower3 = TriggerCreate("gt_ActivateXelNagaTower3_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: StartBossAi
//--------------------------------------------------------------------------------------------------
bool gt_StartBossAi_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_killingPlayer;
    int lv_enemyRTSPlayer;
    unit lv_spawnUnit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_killingPlayer = UnitGetOwner(lib5A1C9904_gv_jG_KillingUnit);

    // Actions
    if (!runActions) {
        return true;
    }

    if ((lib5A1C9904_gf_GetAllyRTSPlayer(lv_killingPlayer) == lib5A1C9904_gv_rTSPlayer1)) {
        libNtve_gf_CreateUnitsAtPoint2(1, "SpawnedOdin", 0, 13, RegionGetCenter(RegionFromId(8)));
        lv_enemyRTSPlayer = lib5A1C9904_gf_GetEnemyRTSPlayer(13);
        lv_spawnUnit = UnitLastCreated();
    }
    else {
        libNtve_gf_CreateUnitsAtPoint2(1, "SpawnedOdin", 0, 14, RegionGetCenter(RegionFromId(8)));
        lv_enemyRTSPlayer = lib5A1C9904_gf_GetEnemyRTSPlayer(14);
        lv_spawnUnit = UnitLastCreated();
    }
    UnitIssueOrder(lv_spawnUnit, OrderTargetingPoint(AbilityCommand("attack", 0), RegionGetCenter(RegionEntireMap())), c_orderQueueReplace);
    while ((UnitIsAlive(lv_spawnUnit) == true)) {
        if ((UnitOrder(lv_spawnUnit, 0) == null)) {
            if ((lv_enemyRTSPlayer == lib5A1C9904_gv_rTSPlayer1)) {
                UnitIssueOrder(lv_spawnUnit, OrderTargetingPoint(AbilityCommand("attack", 0), UnitGroupCenterOfGroup(lib5A1C9904_gv_rtsPlayer1Buildings)), c_orderQueueReplace);
            }
            else {
                UnitIssueOrder(lv_spawnUnit, OrderTargetingPoint(AbilityCommand("attack", 0), UnitGroupCenterOfGroup(lib5A1C9904_gv_rtsPlayer2Buildings)), c_orderQueueReplace);
            }
        }

        Wait(20.0, c_timeGame);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_StartBossAi_Init () {
    gt_StartBossAi = TriggerCreate("gt_StartBossAi_Func");
}

