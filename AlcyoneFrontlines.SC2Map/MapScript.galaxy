//--------------------------------------------------------------------------------------------------
// Trigger: SetupSpawn1Team1
//--------------------------------------------------------------------------------------------------
bool gt_SetupSpawn1Team1_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unitgroup lv_units;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_units = UnitGroupEmpty();

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitIsAlive(gv_team1Spawner1) == true)) {
        libNtve_gf_CreateUnitsAtPoint2(gv_amountTeam1, gv_team1SpawnUnit, 0, 13, RegionGetCenter(RegionFromId(11)));
        UnitGroupAddUnitGroup(lv_units, UnitLastCreatedGroup());
        UnitGroupIssueOrder(UnitLastCreatedGroup(), OrderTargetingPoint(AbilityCommand("attack", 0), PointFromId(2008666934)), c_orderQueueAddToEnd);
        UnitGroupIssueOrder(UnitLastCreatedGroup(), OrderTargetingPoint(AbilityCommand("attack", 0), PointFromId(1673487216)), c_orderQueueAddToEnd);
        UnitGroupIssueOrder(UnitLastCreatedGroup(), OrderTargetingPoint(AbilityCommand("attack", 0), PointFromId(1063931463)), c_orderQueueAddToEnd);
        UnitGroupIssueOrder(UnitLastCreatedGroup(), OrderTargetingPoint(AbilityCommand("attack", 0), PointFromId(1320118314)), c_orderQueueAddToEnd);
        UnitGroupIssueOrder(UnitLastCreatedGroup(), OrderTargetingPoint(AbilityCommand("attack", 0), PointFromId(1466456382)), c_orderQueueAddToEnd);
        while ((libNtve_gf_UnitGroupIsDead(lv_units) == false)) {
            if ((UnitOrder(UnitGroupUnit(lv_units, 1), 0) == null)) {
                UnitGroupIssueOrder(lv_units, OrderTargetingPoint(AbilityCommand("attack", 0), UnitGroupCenterOfGroup(gv_rtsPlayer2Buildings)), c_orderQueueAddToEnd);
            }

            Wait(20.0, c_timeGame);
        }
    }

    return true;
}

