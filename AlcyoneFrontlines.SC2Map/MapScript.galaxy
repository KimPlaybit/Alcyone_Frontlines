                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/10247238")));
                }
                else {
                }
            }

            lv_raceCheck = gf_IsNonKnownRace(lv_playerToSpawnFor);;
            if ((lv_raceCheck == false)) {
                auto64803708_val = lv_random;
                if (auto64803708_val == 0) {
                    libNtve_gf_UnitCreateFacingPoint(1, "ZealotHero", 0, lv_playerToSpawnFor, PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer2));
                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/4018FDF4")));
                }
                else if (auto64803708_val == 1) {
                    libNtve_gf_UnitCreateFacingPoint(1, "AvengerHero", 0, lv_playerToSpawnFor, PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer2));
                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/99B61F02")));
                }
                else if (auto64803708_val == 2) {
                    libNtve_gf_UnitCreateFacingPoint(1, "DragoonHero", 0, lv_playerToSpawnFor, PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer2));
                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/7FEFDD6F")));
                }
                else if (auto64803708_val == 3) {
                    libNtve_gf_UnitCreateFacingPoint(1, "AdeptHero", 0, lv_playerToSpawnFor, PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer2));
                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/91A95230")));
                }
                else if (auto64803708_val == 4) {
                    libNtve_gf_UnitCreateFacingPoint(1, "CorsairHero", 0, lv_playerToSpawnFor, PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer2));
                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/BF736383")));
                }
                else {
                }
            }

            lv_lastCreatedUnit = UnitLastCreated();
            UnitGroupAdd(gv_revivableUnits, UnitLastCreated());
            gf_StartSoldierAI(lv_startPos, lv_player, lv_lastCreatedUnit);
        }

    }
    return true;
}

