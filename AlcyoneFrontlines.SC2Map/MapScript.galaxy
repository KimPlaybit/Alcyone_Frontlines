//--------------------------------------------------------------------------------------------------
// Trigger: AIBuildQueens
//--------------------------------------------------------------------------------------------------
bool gt_AIBuildQueens_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_queensBuilt;
    int lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_player = UnitGetOwner(EventUnit());

    // Conditions
    if (testConds) {
        if (!(((PlayerType(lv_player) == c_playerTypeComputer) && (UnitGetType(EventUnitCreatedUnit()) == "SpawningPool")))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(31.0, c_timeGame);
    while (!(((PlayerGetPropertyInt(lv_player, c_playerPropSuppliesMade) - PlayerGetPropertyInt(lv_player, c_playerPropSuppliesUsed)) >= 6))) {
        Wait(1.0, c_timeGame);
    }
    UIDisplayMessage(PlayerGroupAlliance(c_playerGroupAlly, lv_player), c_messageAreaSubtitle, StringExternal("Param/Value/B7EC0F6A"));
    PlayerModifyPropertyInt(lv_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lv_player, c_playerPropMinerals) + 450));
    AITrain(lv_player, 0, -1, "Queen", 3);
    return true;
}

