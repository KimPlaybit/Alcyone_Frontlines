            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    DialogSetVisible(gv_hiddenDialog, PlayerGroupSingle(EventPlayer()), false);
    DialogSetVisible(gv_scoreDialog, PlayerGroupSingle(EventPlayer()), true);
    return true;
}

