//--------------------------------------------------------------------------------------------------
// Trigger: IncreaseSize
//--------------------------------------------------------------------------------------------------
bool gt_IncreaseSize_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_scale;
    int lv_indexOfUnit;
    bool lv_unitIsInArray;

    // Automatic Variable Declarations
    int auto93021237_ae;
    const int auto93021237_ai = 1;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!((UnitGetType(EventUnit()) == "HotSTorrasque2"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    auto93021237_ae = gv_sizeIndex;
    lv_indexOfUnit = 0;
    for ( ; ( (auto93021237_ai >= 0 && lv_indexOfUnit <= auto93021237_ae) || (auto93021237_ai < 0 && lv_indexOfUnit >= auto93021237_ae) ) ; lv_indexOfUnit += auto93021237_ai ) {
        if ((gv_unitSizeIndex[lv_indexOfUnit] == EventUnit())) {
            lv_unitIsInArray = true;
            break;
        }

    }
    if ((lv_unitIsInArray == true)) {
        lv_scale = (gv_unitSizes[lv_indexOfUnit] + 10);
        gv_unitSizes[lv_indexOfUnit] = (lv_scale + 10);
    }
    else {
        lv_scale = 55;
        gv_unitSizeIndex[gv_sizeIndex] = EventUnit();
        gv_unitSizes[gv_sizeIndex] = lv_scale;
        gv_sizeIndex = (gv_sizeIndex + 1);
    }
    UnitSetScale(EventUnit(), lv_scale, lv_scale, lv_scale);
    return true;
}

