    lib1_gt_BanelingExplodes = TriggerCreate("lib1_gt_BanelingExplodes_Func");
    TriggerAddEventUnitDamaged(lib1_gt_BanelingExplodes, null, c_unitDamageTypeAny, c_unitDamageEither, "HotSBanelingExplodeLargeSearchDamage");
