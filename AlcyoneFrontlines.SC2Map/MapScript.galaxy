    // Variable Declarations
    unit lv_caster;
    int lv_increase;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_caster = EventUnitDamageSourceUnit();
    lv_increase = (UnitXPGetCurrentLevel(lv_caster, "ZergLevels") * 10);

    // Conditions
    if (testConds) {
        if (!((UnitTypeTestAttribute(UnitGetType(EventUnit()), c_unitAttributeStructure) == false))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitDamage(EventUnitDamageSourceUnit(), "HydraliskImpaleDamage2", EventUnit(), lv_increase);
    return true;
}

