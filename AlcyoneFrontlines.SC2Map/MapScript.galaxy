//--------------------------------------------------------------------------------------------------
// Trigger: MothershipCore Picked
//--------------------------------------------------------------------------------------------------
bool gt_MothershipCorePicked_Func (bool testConds, bool runActions) {
    int init_i;

    // Variable Declarations
    unit lv_createdUnit;
    unit lv_powerSource;
    playergroup[2] lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    for (init_i = 0; init_i <= 1; init_i += 1) {
        lv_player[init_i] = PlayerGroupEmpty();
    }

    // Conditions
    if (testConds) {
        if (!(((gv_playerPicked[EventPlayer()] == false) && ((gv_mothershipTeam1 == EventDialogControl()) || (gv_mothershipTeam2 == EventDialogControl()))))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UIClearMessages(PlayerGroupAll(), c_messageAreaChat);
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(EventPlayer()) + StringExternal("Param/Value/331FDE0A")));
    PlayerGroupAdd(lv_player[0], EventPlayer());
    if ((PlayerGetAlliance(gv_rTSPlayer1, c_allianceIdVision, EventPlayer()) == true)) {
        libNtve_gf_UnitCreateFacingPoint(1, "MothershipCoreHero", 0, EventPlayer(), PointFromId(1219627428), PlayerStartLocation(gv_rTSPlayer2));
        lv_createdUnit = UnitLastCreated();
        DialogSetVisible(gv_dialogTeam1, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
        PlayerSetAlliance(EventPlayer(), c_allianceIdPower, gv_rTSPlayer1, true);
        PlayerSetAlliance(gv_rTSPlayer1, c_allianceIdPower, EventPlayer(), true);
        PlayerSetAlliance(13, c_allianceIdPower, EventPlayer(), true);
        PlayerSetAlliance(13, c_allianceIdPower, EventPlayer(), true);
    }
    else {
        libNtve_gf_UnitCreateFacingPoint(1, "MothershipCoreHero", 0, EventPlayer(), PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer1));
        lv_createdUnit = UnitLastCreated();
        DialogSetVisible(gv_dialogTeam2, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
        PlayerSetAlliance(EventPlayer(), c_allianceIdPower, gv_rTSPlayer2, true);
        PlayerSetAlliance(gv_rTSPlayer2, c_allianceIdPower, EventPlayer(), true);
        PlayerSetAlliance(14, c_allianceIdPower, EventPlayer(), true);
    }
    UnitGroupAdd(gv_revivableUnits, lv_createdUnit);
    UnitControlGroupAddUnit(EventPlayer(), 1, lv_createdUnit);
    gv_playerPicked[EventPlayer()] = true;
    PlayerGroupAdd(gv_playersWhoPicked, EventPlayer());
    return true;
}

