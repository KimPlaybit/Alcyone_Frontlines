void lib1_gf_SpawnDefenceTower (int lp_rTSPlayer, int lp_spawnForPlayer, point lp_spawn, point lp_facing) {
    // Variable Declarations
    bool lv_raceCheck;
    bool lv_turret;
    string lv_race;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_turret = lib1_gf_GetTurretStatus();
    lv_race = lib1_gf_GetPlayerRaceName(lp_rTSPlayer);

    // Implementation
    if ((lv_turret == true)) {
        lv_raceCheck = lib1_gf_IsTerran(lp_rTSPlayer);
        if ((lv_raceCheck == true)) {
            libNtve_gf_UnitCreateFacingPoint(1, "KorhalPalaceTurret", 0, lp_spawnForPlayer, lp_spawn, lp_facing);
        }

        lv_raceCheck = lib1_gf_IsZerg(lp_rTSPlayer);
        if ((lv_raceCheck == true)) {
            libNtve_gf_UnitCreateFacingPoint(1, "HugeSpineCrawler", 0, lp_spawnForPlayer, lp_spawn, lp_facing);
        }

        lv_raceCheck = lib1_gf_IsProtoss(lp_rTSPlayer);
        if ((lv_raceCheck == true)) {
            libNtve_gf_UnitCreateFacingPoint(1, "KhaydarinMonolith", 0, lp_spawnForPlayer, lp_spawn, lp_facing);
        }

        lv_raceCheck = lib1_gf_IsKnownRace(lp_rTSPlayer);
        if ((lv_raceCheck == false)) {
            libNtve_gf_UnitCreateFacingPoint(1, "KhaydarinMonolith", 0, lp_spawnForPlayer, lp_spawn, lp_facing);
        }

    }

}

