bool gt_AIBuildShieldBattery_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_player = UnitGetOwner(EventUnit());

    // Conditions
    if (testConds) {
        if (!(((PlayerType(lv_player) == c_playerTypeComputer) && (UnitGetType(EventUnitCreatedUnit()) == "CyberneticsCore")))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(51.0, c_timeGame);
    UIDisplayMessage(PlayerGroupAlliance(c_playerGroupAlly, lv_player), c_messageAreaSubtitle, StringExternal("Param/Value/8F4B5587"));
    PlayerModifyPropertyInt(lv_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lv_player, c_playerPropMinerals) + 450));
    AIBuild(lv_player, 0, -1, "ShieldBattery", 3, -1);
    return true;
}

