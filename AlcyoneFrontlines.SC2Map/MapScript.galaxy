            lv_healUnit = UnitGroupUnitFromEnd(autoA3B73AAB_g, autoA3B73AAB_u);
            if (lv_healUnit == null) { break; }
        }
        return UnitGroupClosestToPoint(lv_healUnits, UnitGetPosition(lp_unit));
    }

    if ((libNtve_gf_PlayerIsEnemy(UnitGetOwner(lp_unit), gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true)) {
        UnitGroupAddUnitGroup(lv_healUnits, gv_rtsPlayer1TownBuilding);
    }
    else {
        UnitGroupAddUnitGroup(lv_healUnits, gv_rtsPlayer2TownBuilding);
    }
    if ((libNtve_gf_UnitGroupIsDead(lv_healUnits) == false)) {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(UnitGetOwner(lp_unit)) + StringExternal("Param/Value/0592D05E")));
        return UnitGroupClosestToPoint(lv_healUnits, UnitGetPosition(lp_unit));
