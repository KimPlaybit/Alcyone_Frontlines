            return lv_pickedUnit;
        }
    }

    if ((libNtve_gf_PlayerIsEnemy(UnitGetOwner(lp_unit), lib1_gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true)) {
        UnitGroupAddUnitGroup(lv_healUnits, lib1_gv_rtsPlayer1TownBuilding);
    }
    else {
        UnitGroupAddUnitGroup(lv_healUnits, lib1_gv_rtsPlayer2TownBuilding);
    }
    if ((libNtve_gf_UnitGroupIsDead(lv_healUnits) == false)) {
        return UnitGroupClosestToPoint(lv_healUnits, UnitGetPosition(lp_unit));
    }

    return null;
}

unit lib1_gf_FindEnemyHero (unit lp_unit) {
    // Variable Declarations
    unitgroup lv_unitsClose;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unitsClose = UnitGroupEmpty();

    // Implementation
    UnitGroupAddUnitGroup(lv_unitsClose, UnitGroupSearch(null, UnitGetOwner(lp_unit), UnitGetPosition(lp_unit), 12.0, UnitFilter((1 << c_targetFilterHeroic), 0, (1 << c_targetFilterPlayer) | (1 << c_targetFilterAlly) | (1 << c_targetFilterNeutral) | (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0));
    if ((libNtve_gf_UnitGroupIsDead(lv_unitsClose) == false)) {
        return lp_unit;
    }
    else {
        return null;
    }
}

unitgroup lib1_gf_GetSpawners (int lp_player) {
