point gf_GetSpawnPointTeam1 (unit lp_deadPlayer) {
    // Variable Declarations
    unit lv_unit;

    // Automatic Variable Declarations
    // Variable Initialization

    // Implementation
    if ((libNtve_gf_UnitGroupIsDead(gv_rtsPlayer1TownBuilding) == false)) {
        lv_unit = UnitGroupClosestToPoint(gv_rtsPlayer1TownBuilding, UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lp_deadPlayer)));
        return UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
    }

    if ((libNtve_gf_UnitGroupIsDead(gv_rtsPlayer1Buildings) == false)) {
        lv_unit = UnitGroupClosestToPoint(gv_rtsPlayer1Buildings, UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lp_deadPlayer)));
        return UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
    }

    return PointFromId(1219627428);
}

int gf_GetAllyRTSPlayer (int lp_player) {
    // Automatic Variable Declarations
    // Implementation
    if ((libNtve_gf_PlayerIsEnemy(lp_player, gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true)) {
        return gv_rTSPlayer1;
    }
    else {
        return gv_rTSPlayer2;
    }
}

int gf_GetEnemyRTSPlayer (int lp_player) {
    // Automatic Variable Declarations
    // Implementation
    if ((libNtve_gf_PlayerIsEnemy(lp_player, gv_rTSPlayer1, libNtve_ge_PlayerRelation_Enemy) == true)) {
        return gv_rTSPlayer1;
    }
    else {
        return gv_rTSPlayer2;
    }
}

point gf_GetSpawnPointTeam2 (unit lp_deadPlayer) {
    // Variable Declarations
    unit lv_unit;

    // Automatic Variable Declarations
    // Variable Initialization

    // Implementation
    if ((libNtve_gf_UnitGroupIsDead(gv_rtsPlayer2TownBuilding) == false)) {
        lv_unit = UnitGroupClosestToPoint(gv_rtsPlayer2TownBuilding, UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lp_deadPlayer)));
        return UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
    }

    if ((libNtve_gf_UnitGroupIsDead(gv_rtsPlayer2Buildings) == false)) {
        lv_unit = UnitGroupClosestToPoint(gv_rtsPlayer2Buildings, UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lp_deadPlayer)));
        return UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
    }

    return PointFromId(1466456382);
}

point gf_GetStartLocation (int lp_player) {
    // Automatic Variable Declarations
    // Implementation
    if ((libNtve_gf_PlayerIsEnemy(lp_player, gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true)) {
        return PointFromId(1219627428);
    }
    else {
        return PointFromId(1466456382);
    }
}

void gf_GiveResource (unit lp_killedUnit, int lp_player, int lp_killingPlayer) {
    // Variable Declarations
    int lv_triggeringPlayerKills;
    int lv_triggeringPlayerDeaths;
    int lv_triggeringPlayerMinerals;
    int lv_triggeringPlayerGas;

    // Automatic Variable Declarations
    string autoF73D17EE_val;

    // Variable Initialization
    lv_triggeringPlayerKills = gv_playerKills[lp_killingPlayer];
    lv_triggeringPlayerDeaths = gv_playerDeaths[lp_killingPlayer];
    lv_triggeringPlayerMinerals = gv_playerMineral[lp_killingPlayer];
    lv_triggeringPlayerGas = gv_playerGas[lp_killingPlayer];

    // Implementation
    autoF73D17EE_val = UnitGetType(lp_killedUnit);
    if (autoF73D17EE_val == "Zergling2") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 10));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 10, lv_triggeringPlayerGas, lp_killingPlayer);
    }
