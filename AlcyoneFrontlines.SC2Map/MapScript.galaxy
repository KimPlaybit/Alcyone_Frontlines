//--------------------------------------------------------------------------------------------------
// Custom AI Functions
//--------------------------------------------------------------------------------------------------
string[17] cai_playerAI;

//--------------------------------------------------------------------------------------------------
void InitCustomAI () {
    int init_i;

    for (init_i = 0; init_i <= 16; init_i += 1) {
        cai_playerAI[init_i] = null;
    }
}

//--------------------------------------------------------------------------------------------------
void cai_start (string ai, int p) {
    if (p < 0 || p >= 16) {
        return;
    }
    cai_playerAI[p] = ai;

    if (cai_playerAI[p] == "ai00CAC601") { ai00CAC601_start(p); }
    if (cai_playerAI[p] == "ai1E9CC8C8") { ai1E9CC8C8_start(p); }
    if (cai_playerAI[p] == "ai6C673424") { ai6C673424_start(p); }
}

//--------------------------------------------------------------------------------------------------
void cai_setDefGather (int p, point val) {
    if (p < 0 || p >= 16) {
        return;
    }
    if (cai_playerAI[p] == "ai00CAC601") { ai00CAC601_setDefGather(p, val); }
    if (cai_playerAI[p] == "ai1E9CC8C8") { ai1E9CC8C8_setDefGather(p, val); }
    if (cai_playerAI[p] == "ai6C673424") { ai6C673424_setDefGather(p, val); }
}

//--------------------------------------------------------------------------------------------------
string cai_getCustomData (int p) {
    if (p < 0 || p >= 16) {
        return null;
    }
    if (cai_playerAI[p] == "ai00CAC601") { return ai00CAC601_getCustomData(p); }
    if (cai_playerAI[p] == "ai1E9CC8C8") { return ai1E9CC8C8_getCustomData(p); }
