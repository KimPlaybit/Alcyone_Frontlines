//--------------------------------------------------------------------------------------------------
// Trigger: WinTeam1
//--------------------------------------------------------------------------------------------------
bool gt_WinTeam1_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_loopedPlayer;

    // Automatic Variable Declarations
    playergroup auto73FCF83D_g;
    playergroup auto742220C0_g;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!(((UnitCount(null, gv_rTSPlayer2, RegionEntireMap(), UnitFilter((1 << c_targetFilterStructure), 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32)) | (1 << (c_targetFilterInvulnerable - 32))), 10) == 0) && (UnitTypeTestAttribute(UnitGetType(EventUnit()), c_unitAttributeStructure) == true) && (gf_IsSurvival() == false)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    GameOver(gv_rTSPlayer1, c_gameOverVictory, true, true);
    GameOver(gv_rTSPlayer2, c_gameOverDefeat, true, true);
    auto73FCF83D_g = gv_soldierPlayers1;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(auto73FCF83D_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        GameOver(lv_loopedPlayer, c_gameOverVictory, true, true);
    }
    auto742220C0_g = gv_soldierPlayers2;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(auto742220C0_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        GameOver(lv_loopedPlayer, c_gameOverDefeat, true, true);
    }
    return true;
}

