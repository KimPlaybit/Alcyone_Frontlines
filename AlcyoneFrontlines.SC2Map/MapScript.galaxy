// Functions
void lib1_gf_StartProximaGame () {
    // Variable Declarations
    bool lv_waves;
    string lv_raceName;
    point lv_startpos1;
    point lv_startpos2;
    point lv_offsetplayer1;
    point lv_offsetplayer2;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_waves = lib1_gf_GetWaveStatus();
    lv_raceName = "";
    lv_startpos1 = PointFromId(1219627428);
    lv_startpos2 = PointFromId(1466456382);
    lv_offsetplayer1 = PointWithOffset(PointFromId(1219627428), 3.0, 3.0);
    lv_offsetplayer2 = PointWithOffset(PointFromId(1466456382), -2.0, -3.0);

    // Implementation
    if ((lib1_gf_IsSurvival() == true)) {
        if ((lib1_gf_WithRTSPlayer() == true)) {
            lib1_gv_soldierPlayers1 = GameAttributePlayersForTeam(2);
            MeleeInitUnitsForPlayer(lib1_gv_rTSPlayer1, PlayerRace(lib1_gv_rTSPlayer1), PointFromId(1219627428));
            lib1_gf_SpawnDefenceTower(lib1_gv_rTSPlayer1, 13, lv_offsetplayer1, lv_startpos2);
        }
        else {
            lib1_gv_soldierPlayers1 = GameAttributePlayersForTeam(2);
            PlayerGroupAdd(lib1_gv_soldierPlayers1, lib1_gv_rTSPlayer1);
        }
    }
    else {
        lib1_gv_soldierPlayers1 = GameAttributePlayersForTeam(3);
        lib1_gv_soldierPlayers2 = GameAttributePlayersForTeam(4);
        MeleeInitUnitsForPlayer(lib1_gv_rTSPlayer1, PlayerRace(lib1_gv_rTSPlayer1), PointFromId(1219627428));
        lib1_gf_SpawnDefenceTower(lib1_gv_rTSPlayer1, 13, lv_offsetplayer1, lv_startpos2);
        MeleeInitUnitsForPlayer(lib1_gv_rTSPlayer2, PlayerRace(lib1_gv_rTSPlayer2), PointFromId(1466456382));
        lib1_gf_SpawnDefenceTower(lib1_gv_rTSPlayer2, 14, lv_offsetplayer2, lv_startpos1);
    }
    lib1_gf_SetupTeams1();
    lib1_gf_SetupTeams2();
    MeleeInitResourcesForPlayer(lib1_gv_rTSPlayer1, PlayerRace(lib1_gv_rTSPlayer1));
    MeleeInitResourcesForPlayer(lib1_gv_rTSPlayer2, PlayerRace(lib1_gv_rTSPlayer2));
    libNtve_gf_SetUpgradeLevelForPlayer(13, "ShrikeTurret", 1);
    libNtve_gf_SetUpgradeLevelForPlayer(14, "ShrikeTurret", 1);
    CameraPan(lib1_gv_rTSPlayer1, PointFromId(1219627428), 0.0, -1, 10.0, false);
    CameraPan(lib1_gv_rTSPlayer2, PointFromId(1466456382), 0.0, -1, 10.0, false);
    lib1_gf_StartAi(lv_startpos1, lib1_gv_rTSPlayer1);
    lib1_gf_StartAi(lv_startpos2, lib1_gv_rTSPlayer2);
    Wait(0.5, c_timeGame);
    lib1_gf_Scores();
    lib1_gf_SoldierSelectionTeam1();
    lib1_gf_SoldierSelectionTeam2();
    Wait(0.5, c_timeGame);
    UISetAlertTypeVisible(PlayerGroupAll(), "AttackUnitAlly_Prot", false);
    UISetAlertTypeVisible(PlayerGroupAll(), "AttackUnitAlly_Zerg", false);
    UISetAlertTypeVisible(PlayerGroupAll(), "AttackUnitAlly_Terr", false);
    lib1_gf_CreateSpawners();
    lib1_gf_SpawnJungleUnits();
}

