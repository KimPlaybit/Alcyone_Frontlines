//--------------------------------------------------------------------------------------------------
// Trigger: Revive Heroes Team 1
//--------------------------------------------------------------------------------------------------
bool gt_ReviveHeroesTeam1_Func (bool testConds, bool runActions) {
    // Variable Declarations
    point lv_spawnPoint;
    int lv_triggeringPlayerKills;
    int lv_triggeringPlayerDeaths;
    int lv_triggeringPlayerMinerals;
    int lv_triggeringPlayerGas;
    int lv_triggeringPlayer;
    int lv_killingPlayer;
    int lv_killingPlayersKills;
    int lv_killingPlayersDeaths;
    int lv_killingPlayerMinerals;
    int lv_killingPlayerGas;
    unit lv_dyingUnit;
    timer lv_deathTimer;
    int lv_timerWindow;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_spawnPoint = PointFromId(1219627428);
    lv_triggeringPlayerKills = gv_playerKills[EventPlayer()];
    lv_triggeringPlayerDeaths = (gv_playerDeaths[EventPlayer()] + 1);
    lv_triggeringPlayerMinerals = gv_playerMineral[EventPlayer()];
    lv_triggeringPlayerGas = gv_playerGas[EventPlayer()];
    lv_triggeringPlayer = EventPlayer();
    lv_killingPlayer = libNtve_gf_KillingPlayer();
    lv_killingPlayersKills = gv_playerKills[libNtve_gf_KillingPlayer()];
    lv_killingPlayersDeaths = gv_playerDeaths[libNtve_gf_KillingPlayer()];
    lv_killingPlayerMinerals = (gv_playerMineral[libNtve_gf_KillingPlayer()] + 350);
    lv_killingPlayerGas = (gv_playerGas[libNtve_gf_KillingPlayer()] + 200);
    lv_dyingUnit = EventUnit();
    lv_deathTimer = TimerCreate();
    lv_timerWindow = c_timerWindowNone;

    // Conditions
    if (testConds) {
        if (!((((UnitGetOwner(lv_dyingUnit) == gv_rTSPlayer1) && (UnitTypeTestFlag(UnitGetType(lv_dyingUnit), c_unitFlagHero) == true) && (PlayerType(gv_rTSPlayer1) == c_playerTypeComputer) && (UnitGroupHasUnit(gv_revivableUnits, EventUnit()) == true)) || ((UnitGroupHasUnit(gv_revivableUnits, EventUnit()) == true) && (UnitTypeTestFlag(UnitGetType(lv_dyingUnit), c_unitFlagHero) == true) && (PlayerGroupHasPlayer(PlayerGroupAlliance(c_playerGroupAlly, gv_rTSPlayer1), UnitGetOwner(EventUnit())) == true))))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals, lv_triggeringPlayerGas, lv_triggeringPlayer);
    if ((gf_WithRTSPlayer() == false)) {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(EventPlayer()) + (StringExternal("Param/Value/080E41B7") + (UnitGetName(EventUnit()) + StringExternal("Param/Value/4572AFAD")))));
        GameOver(lv_triggeringPlayer, c_gameOverDefeat, true, true);
        return false;
    }
    else {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(EventPlayer()) + (StringExternal("Param/Value/78E1C15D") + (UnitGetName(EventUnit()) + (StringExternal("Param/Value/1EC38BFD") + (PlayerName(libNtve_gf_KillingPlayer()) + (StringExternal("Param/Value/46914403") + (IntToText(gv_ressTimer) + StringExternal("Param/Value/8DBB0D73")))))))));
    }
    gf_GiveXPForHeroKills(libNtve_gf_KillingUnit(), lv_dyingUnit);
    gf_ResetCooldownOfShadowFury(libNtve_gf_KillingUnit());
    if ((((libNtve_gf_PlayerIsEnemy(UnitGetOwner(libNtve_gf_KillingUnit()), gv_rTSPlayer2, libNtve_ge_PlayerRelation_Ally) == true) || (libNtve_gf_PlayerIsEnemy(UnitGetOwner(libNtve_gf_KillingUnit()), gv_rTSPlayer2, libNtve_ge_PlayerRelation_Neutral) == true)) && (libNtve_gf_PlayerIsEnemy(UnitGetOwner(libNtve_gf_KillingUnit()), lv_triggeringPlayer, libNtve_ge_PlayerRelation_Enemy) == true))) {
        gf_UpdateScoreboard(lv_killingPlayersKills + 1, lv_killingPlayersDeaths, lv_killingPlayerMinerals, lv_killingPlayerGas, lv_killingPlayer);
        PlayerModifyPropertyInt(gv_rTSPlayer2, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(gv_rTSPlayer2, c_playerPropMinerals) + 350));
        PlayerModifyPropertyInt(gv_rTSPlayer2, c_playerPropVespene, c_playerPropOperSetTo, (PlayerGetPropertyInt(gv_rTSPlayer2, c_playerPropVespene) + 200));
    }

    UnitSetState(lv_dyingUnit, c_unitStateHighlightable, false);
    UnitSetState(lv_dyingUnit, c_unitStateCursorable, false);
    UnitSetState(lv_dyingUnit, c_unitStateSelectable, false);
    UnitSetState(lv_dyingUnit, c_unitStateTooltipable, false);
    UnitSetState(lv_dyingUnit, c_unitStateStatusBar, false);
    UnitSetState(lv_dyingUnit, c_unitStateHidden, true);
    UnitSetState(lv_dyingUnit, c_unitStateSleeping, true);
    UnitSetState(lv_dyingUnit, c_unitStateStunned, true);
    libNtve_gf_MakeUnitInvulnerable(lv_dyingUnit, true);
    lv_spawnPoint = gf_GetSpawnPointTeam1(lv_dyingUnit);
    UnitSetPosition(lv_dyingUnit, PointWithOffset(lv_spawnPoint, 0.0, 3.0), false);
    UnitRevive(lv_dyingUnit);
    lv_deathTimer = TimerCreate();
    TimerWindowCreate(lv_deathTimer, StringToText(""), false, false);
    TimerStart(lv_deathTimer, gv_ressTimer, false, c_timeReal);
    lv_timerWindow = TimerWindowLastCreated();
    TimerWindowShow(lv_timerWindow, PlayerGroupSingle(lv_triggeringPlayer), true);
    Wait(gv_ressTimer, c_timeReal);
    lv_spawnPoint = gf_GetSpawnPointTeam1(lv_dyingUnit);
    UnitSetPosition(lv_dyingUnit, PointWithOffset(lv_spawnPoint, 0.0, 3.0), false);
    libNtve_gf_StopTimer(lv_deathTimer);
    TimerWindowDestroy(lv_timerWindow);
    libNtve_gf_MakeUnitInvulnerable(lv_dyingUnit, false);
    UnitSetState(lv_dyingUnit, c_unitStateHighlightable, true);
    UnitSetState(lv_dyingUnit, c_unitStateCursorable, true);
    UnitSetState(lv_dyingUnit, c_unitStateSelectable, true);
    UnitSetState(lv_dyingUnit, c_unitStateTooltipable, true);
    UnitSetState(lv_dyingUnit, c_unitStateStatusBar, true);
    UnitSetState(lv_dyingUnit, c_unitStateStunned, false);
    UnitSetState(lv_dyingUnit, c_unitStateHidden, false);
    UnitSetState(lv_dyingUnit, c_unitStateSleeping, false);
    UnitSetPropertyFixed(lv_dyingUnit, c_unitPropLifePercent, 100.0);
    UnitSetPropertyFixed(lv_dyingUnit, c_unitPropShieldsPercent, 100.0);
    CameraPan(UnitGetOwner(lv_dyingUnit), lv_spawnPoint, 0.0, -1, 10.0, false);
    UnitClearSelection(UnitGetOwner(lv_dyingUnit));
    UnitSelect(lv_dyingUnit, UnitGetOwner(lv_dyingUnit), true);
    if ((UnitGetType(EventUnit()) == "HotSTorrasque2")) {
        gf_SetSize(lv_dyingUnit);
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_ReviveHeroesTeam1_Init () {
    gt_ReviveHeroesTeam1 = TriggerCreate("gt_ReviveHeroesTeam1_Func");
    TriggerAddEventUnitDied(gt_ReviveHeroesTeam1, null);
}

