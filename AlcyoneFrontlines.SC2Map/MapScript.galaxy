        libNtve_gf_UnitCreateFacingPoint(1, "NydusCanal22", 0, EventPlayer(), PointFromId(1219627428), PlayerStartLocation(gv_rTSPlayer2));
        DialogSetVisible(gv_dialogTeam1, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    else {
        libNtve_gf_UnitCreateFacingPoint(1, "NydusCanal22", 0, EventPlayer(), PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer1));
        DialogSetVisible(gv_dialogTeam2, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    UnitGroupAdd(gv_revivableUnits, UnitLastCreated());
    UnitControlGroupAddUnit(EventPlayer(), 1, UnitLastCreated());
    gv_playerPicked[EventPlayer()] = true;
    PlayerGroupAdd(gv_playersWhoPicked, EventPlayer());
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_NydusPicked_Init () {
    gt_NydusPicked = TriggerCreate("gt_NydusPicked_Func");
    TriggerAddEventDialogControl(gt_NydusPicked, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Science Vessel Picked
//--------------------------------------------------------------------------------------------------
bool gt_ScienceVesselPicked_Func (bool testConds, bool runActions) {
    int init_i;

    // Variable Declarations
    playergroup[2] lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    for (init_i = 0; init_i <= 1; init_i += 1) {
        lv_player[init_i] = PlayerGroupEmpty();
    }

    // Conditions
    if (testConds) {
        if (!(((gv_playerPicked[EventPlayer()] == false) && ((gv_scienceVesselTeam1 == EventDialogControl()) || (gv_scienceVesselTeam2 == EventDialogControl()))))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UIClearMessages(PlayerGroupAll(), c_messageAreaChat);
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(EventPlayer()) + StringExternal("Param/Value/0C3AC057")));
    PlayerGroupAdd(lv_player[0], EventPlayer());
    if ((PlayerGetAlliance(gv_rTSPlayer1, c_allianceIdVision, EventPlayer()) == true)) {
        libNtve_gf_UnitCreateFacingPoint(1, "ScienceVessel2", 0, EventPlayer(), PointFromId(1219627428), PlayerStartLocation(gv_rTSPlayer2));
        DialogSetVisible(gv_dialogTeam1, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    else {
        libNtve_gf_UnitCreateFacingPoint(1, "ScienceVessel2", 0, EventPlayer(), PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer1));
        DialogSetVisible(gv_dialogTeam2, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    UnitGroupAdd(gv_revivableUnits, UnitLastCreated());
    UnitControlGroupAddUnit(EventPlayer(), 1, UnitLastCreated());
    gv_playerPicked[EventPlayer()] = true;
    PlayerGroupAdd(gv_playersWhoPicked, EventPlayer());
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_ScienceVesselPicked_Init () {
    gt_ScienceVesselPicked = TriggerCreate("gt_ScienceVesselPicked_Func");
    TriggerAddEventDialogControl(gt_ScienceVesselPicked, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}

