// Trigger: Scores
//--------------------------------------------------------------------------------------------------
bool gt_Scores_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_index;
    int lv_loopedPlayer;

    // Automatic Variable Declarations
    playergroup auto0DF8FD72_g;
    playergroup autoD12109AD_g;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    DialogCreate(400, ((PlayerGroupCount(PlayerGroupActive()) * 33) + 50), c_anchorTopLeft, 0, 0, true);
    gv_scoreDialog = DialogLastCreated();
    libNtve_gf_CreateDialogItemButton(gv_scoreDialog, 45, 45, c_anchorTopLeft, 30, 30, StringExternal("Param/Value/669A60E2"), StringExternal("Param/Value/C228B161"), "");
    gv_hideScore = DialogControlLastCreated();
    DialogSetVisible(gv_scoreDialog, PlayerGroupSingle(gv_rTSPlayer1), true);
    DialogSetVisible(gv_scoreDialog, PlayerGroupSingle(gv_rTSPlayer2), true);
    DialogSetVisible(gv_scoreDialog, gv_soldierPlayers1, true);
    DialogSetVisible(gv_scoreDialog, gv_soldierPlayers2, true);
    libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 120, 50, c_anchorTopLeft, 32, 72, StringExternal("Param/Value/31112E3F"), ColorWithAlpha(0,0,0,0), false, 0.0);
    libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 50, 50, c_anchorTopLeft, 155, 72, StringExternal("Param/Value/B141605D"), ColorWithAlpha(0,0,0,0), false, 0.0);
    libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 150, 25, c_anchorTopLeft, 240, 72, StringExternal("Param/Value/EFBB3CAD"), ColorWithAlpha(0,0,0,0), false, 0.0);
    gv_playerKills[gv_rTSPlayer1] = 0;
    gv_playerDeaths[gv_rTSPlayer1] = 0;
    gv_playerMineral[gv_rTSPlayer1] = 0;
    gv_playerGas[gv_rTSPlayer1] = 0;
    gv_playerKills[gv_rTSPlayer2] = 0;
    gv_playerDeaths[gv_rTSPlayer2] = 0;
    gv_playerMineral[gv_rTSPlayer2] = 0;
    gv_playerGas[gv_rTSPlayer2] = 0;
    auto0DF8FD72_g = gv_soldierPlayers1;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(auto0DF8FD72_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        gv_playerKills[lv_loopedPlayer] = 0;
        gv_playerDeaths[lv_loopedPlayer] = 0;
        gv_playerMineral[lv_loopedPlayer] = 0;
        gv_playerGas[lv_loopedPlayer] = 0;
        libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 120, 25, c_anchorTopLeft, 32, ((28 * lv_index) + 90), PlayerName(lv_loopedPlayer), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(lv_loopedPlayer, false)), false, 0.0);
        libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 110, 25, c_anchorTopLeft, 155, ((28 * lv_index) + 90), StringExternal("Param/Value/C61C79E4"), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(lv_loopedPlayer, false)), false, 0.0);
        gv_playerStats[lv_loopedPlayer] = DialogControlLastCreated();
        libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 150, 25, c_anchorTopLeft, 240, ((28 * lv_index) + 90), StringExternal("Param/Value/1EE8BF2C"), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(lv_loopedPlayer, false)), false, 0.0);
        gv_playerMiGa[lv_loopedPlayer] = DialogControlLastCreated();
        lv_index = (lv_index + 1);
    }
    libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 120, 50, c_anchorTopLeft, 32, ((lv_index * 28) + 90), StringExternal("Param/Value/6A15CB11"), ColorWithAlpha(0,0,0,0), false, 0.0);
    lv_index = (lv_index + 1);
    autoD12109AD_g = gv_soldierPlayers2;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(autoD12109AD_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        gv_playerKills[lv_loopedPlayer] = 0;
        gv_playerDeaths[lv_loopedPlayer] = 0;
        gv_playerMineral[lv_loopedPlayer] = 0;
        gv_playerGas[lv_loopedPlayer] = 0;
        libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 120, 25, c_anchorTopLeft, 32, ((28 * lv_index) + 80), PlayerName(lv_loopedPlayer), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(lv_loopedPlayer, false)), false, 0.0);
        libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 110, 25, c_anchorTopLeft, 155, ((28 * lv_index) + 80), StringExternal("Param/Value/129836C1"), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(lv_loopedPlayer, false)), false, 0.0);
        gv_playerStats[lv_loopedPlayer] = DialogControlLastCreated();
        libNtve_gf_CreateDialogItemLabel(gv_scoreDialog, 150, 25, c_anchorTopLeft, 240, ((28 * lv_index) + 80), StringExternal("Param/Value/9632B630"), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(lv_loopedPlayer, false)), false, 0.0);
        gv_playerMiGa[lv_loopedPlayer] = DialogControlLastCreated();
        lv_index = (lv_index + 1);
    }
    DialogCreate(45, 45, c_anchorTopLeft, 0, 0, true);
    gv_hiddenDialog = DialogLastCreated();
    libNtve_gf_CreateDialogItemButton(gv_hiddenDialog, 45, 45, c_anchorTopLeft, 0, 0, StringExternal("Param/Value/BCCB2F63"), StringExternal("Param/Value/00091908"), "");
    gv_showScore = DialogControlLastCreated();
    return true;
}

