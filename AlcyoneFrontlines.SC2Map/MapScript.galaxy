//--------------------------------------------------------------------------------------------------
void cai_start (string ai, int p) {
    if (p < 0 || p >= 16) {
        return;
    }
    cai_playerAI[p] = ai;

    if (cai_playerAI[p] == "ai00CAC601") { ai00CAC601_start(p); }
    if (cai_playerAI[p] == "ai1E9CC8C8") { ai1E9CC8C8_start(p); }
    if (cai_playerAI[p] == "ai6C673424") { ai6C673424_start(p); }
}

