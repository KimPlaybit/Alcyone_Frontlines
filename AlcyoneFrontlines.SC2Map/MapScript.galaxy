//--------------------------------------------------------------------------------------------------
// Trigger: AIBuildMedivacs
//--------------------------------------------------------------------------------------------------
bool gt_AIBuildMedivacs_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_queensBuilt;
    int lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_player = UnitGetOwner(EventUnit());

    // Conditions
    if (testConds) {
        if (!(((PlayerType(lv_player) == c_playerTypeComputer) && (UnitGetType(EventUnitCreatedUnit()) == "Factory")))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(60.0, c_timeGame);
    PlayerModifyPropertyInt(lv_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lv_player, c_playerPropMinerals) + 150));
    PlayerModifyPropertyInt(lv_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lv_player, c_playerPropVespene) + 100));
    AIBuild(lv_player, 0, -1, "Starport", 1, -1);
    Wait(40.0, c_timeGame);
    while (!(((PlayerGetPropertyInt(lv_player, c_playerPropSuppliesMade) - PlayerGetPropertyInt(lv_player, c_playerPropSuppliesUsed)) >= 6))) {
        Wait(1.0, c_timeGame);
    }
    UIDisplayMessage(PlayerGroupAlliance(c_playerGroupAlly, lv_player), c_messageAreaSubtitle, StringExternal("Param/Value/2AB4679B"));
    PlayerModifyPropertyInt(lv_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lv_player, c_playerPropMinerals) + 300));
    PlayerModifyPropertyInt(lv_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lv_player, c_playerPropVespene) + 300));
    AITrain(lv_player, 0, -1, "Medivac", 3);
    return true;
}

