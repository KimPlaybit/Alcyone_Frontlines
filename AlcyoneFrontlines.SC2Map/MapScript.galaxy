unit gf_FindHealspot (unit lp_unit) {
    // Variable Declarations
    unitgroup lv_healUnits;
    unit lv_healUnit;
    unit lv_loopUnit;
    unit lv_pickedUnit;

    // Automatic Variable Declarations
    unitgroup autoA3B73AAB_g;
    int autoA3B73AAB_u;

    // Variable Initialization
    lv_healUnits = UnitGroupEmpty();

    // Implementation
    if ((libNtve_gf_PlayerIsEnemy(UnitGetOwner(lp_unit), gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true)) {
        if ((gf_IsZerg(gv_rTSPlayer1) == true)) {
            return UnitGroupUnit(gv_rtsPlayer1TownBuilding, 1);
        }
        else {
            UnitGroupAddUnitGroup(lv_healUnits, gv_healUnitsRTS1);
        }
    }
    else {
        if ((gf_IsZerg(gv_rTSPlayer2) == true)) {
            return UnitGroupUnit(gv_rtsPlayer2TownBuilding, 1);
        }
        else {
            UnitGroupAddUnitGroup(lv_healUnits, gv_healUnitsRTS2);
        }
    }
    if ((libNtve_gf_UnitGroupIsDead(lv_healUnits) == false)) {
        autoA3B73AAB_g = lv_healUnits;
        autoA3B73AAB_u = UnitGroupCount(autoA3B73AAB_g, c_unitCountAll);
        for (;; autoA3B73AAB_u -= 1) {
            lv_loopUnit = UnitGroupUnitFromEnd(autoA3B73AAB_g, autoA3B73AAB_u);
            if (lv_loopUnit == null) { break; }
            if (((lv_pickedUnit == null) || (UnitGetPropertyFixed(lv_loopUnit, c_unitPropEnergy, c_unitPropCurrent) > UnitGetPropertyFixed(lv_healUnit, c_unitPropEnergy, c_unitPropCurrent)))) {
                lv_pickedUnit = lv_healUnit;
            }

        }
        if ((lv_pickedUnit == null)) {
            return UnitGroupClosestToPoint(lv_healUnits, UnitGetPosition(lp_unit));
        }
        else {
            return lv_pickedUnit;
        }
    }

    if ((libNtve_gf_PlayerIsEnemy(UnitGetOwner(lp_unit), gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true)) {
        UnitGroupAddUnitGroup(lv_healUnits, gv_rtsPlayer1TownBuilding);
    }
    else {
        UnitGroupAddUnitGroup(lv_healUnits, gv_rtsPlayer2TownBuilding);
    }
    if ((libNtve_gf_UnitGroupIsDead(lv_healUnits) == false)) {
        return UnitGroupClosestToPoint(lv_healUnits, UnitGetPosition(lp_unit));
    }

    return null;
}

