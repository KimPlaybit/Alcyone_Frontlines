void gf_GiveResource (unit lp_killedUnit, int lp_player, int lp_killingPlayer) {
    // Variable Declarations
    int lv_triggeringPlayerKills;
    int lv_triggeringPlayerDeaths;
    int lv_triggeringPlayerMinerals;
    int lv_triggeringPlayerGas;

    // Automatic Variable Declarations
    string autoF73D17EE_val;

    // Variable Initialization
    lv_triggeringPlayerKills = gv_playerKills[lp_killingPlayer];
    lv_triggeringPlayerDeaths = gv_playerDeaths[lp_killingPlayer];
    lv_triggeringPlayerMinerals = gv_playerMineral[lp_killingPlayer];
    lv_triggeringPlayerGas = gv_playerGas[lp_killingPlayer];

    // Implementation
    autoF73D17EE_val = UnitGetType(lp_killedUnit);
    if (autoF73D17EE_val == "Zergling2") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 10));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 10, lv_triggeringPlayerGas, lp_killingPlayer);
    }
    else if (autoF73D17EE_val == "Hydralisk2") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 30));
        PlayerModifyPropertyInt(lp_player, c_playerPropVespene, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropVespene) + 5));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 30, lv_triggeringPlayerGas + 5, lp_killingPlayer);
    }
    else if (autoF73D17EE_val == "Odin") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 2000));
        PlayerModifyPropertyInt(lp_player, c_playerPropVespene, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropVespene) + 1000));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 2000, lv_triggeringPlayerGas + 1000, lp_killingPlayer);
    }
    else if (autoF73D17EE_val == "Marine") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 20));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 20, lv_triggeringPlayerGas, lp_killingPlayer);
    }
    else if (autoF73D17EE_val == "Roach2") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 25));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 25, lv_triggeringPlayerGas, lp_killingPlayer);
    }
    else if (autoF73D17EE_val == "VikingFighter") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 25));
        PlayerModifyPropertyInt(lp_player, c_playerPropVespene, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropVespene) + 25));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 25, lv_triggeringPlayerGas + 25, lp_killingPlayer);
    }
    else if (autoF73D17EE_val == "VikingAssault") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 25));
        PlayerModifyPropertyInt(lp_player, c_playerPropVespene, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropVespene) + 25));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 25, lv_triggeringPlayerGas + 25, lp_killingPlayer);
    }
    else if (autoF73D17EE_val == "Marauder") {
        PlayerModifyPropertyInt(lp_player, c_playerPropMinerals, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropMinerals) + 20));
        PlayerModifyPropertyInt(lp_player, c_playerPropVespene, c_playerPropOperSetTo, (PlayerGetPropertyInt(lp_player, c_playerPropVespene) + 5));
        gf_UpdateScoreboard(lv_triggeringPlayerKills, lv_triggeringPlayerDeaths, lv_triggeringPlayerMinerals + 25, lv_triggeringPlayerGas + 5, lp_killingPlayer);
    }
    else {
    }
}

void gf_SpawnDefenceTower (int lp_rTSPlayer, int lp_spawnForPlayer, point lp_spawn, point lp_facing) {
    // Variable Declarations
    bool lv_raceCheck;
    bool lv_turret;
    string lv_race;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_turret = gf_GetTurretStatus();;
    lv_race = gf_GetPlayerRaceName(lp_rTSPlayer);

    // Implementation
    if ((lv_turret == true)) {
        lv_raceCheck = gf_IsTerran(lp_rTSPlayer);;
        if ((lv_raceCheck == true)) {
            libNtve_gf_UnitCreateFacingPoint(1, "KorhalPalaceTurret", 0, lp_spawnForPlayer, lp_spawn, lp_facing);
        }

        lv_raceCheck = gf_IsZerg(lp_rTSPlayer);;
        if ((lv_raceCheck == true)) {
            libNtve_gf_UnitCreateFacingPoint(1, "HugeSpineCrawler", 0, lp_spawnForPlayer, lp_spawn, lp_facing);
        }

        lv_raceCheck = gf_IsProtoss(lp_rTSPlayer);;
        if ((lv_raceCheck == true)) {
            libNtve_gf_UnitCreateFacingPoint(1, "KhaydarinMonolith", 0, lp_spawnForPlayer, lp_spawn, lp_facing);
        }

        lv_raceCheck = gf_IsNonKnownRace(lp_rTSPlayer);;
        if ((lv_raceCheck == false)) {
            libNtve_gf_UnitCreateFacingPoint(1, "KhaydarinMonolith", 0, lp_spawnForPlayer, lp_spawn, lp_facing);
        }

    }

}

string gf_GetPlayerRaceName (int lp_player) {
    // Variable Declarations
    text lv_text;
    string lv_name_of_race;

    // Automatic Variable Declarations
    string auto9AE8C225_val;

    // Variable Initialization
    lv_name_of_race = "";

    // Implementation
    auto9AE8C225_val = PlayerRace(lp_player);
    if (auto9AE8C225_val == "Prot") {
        return "Protoss";
    }
    else if (auto9AE8C225_val == "Terr") {
        return "Terran";
    }
    else if (auto9AE8C225_val == "Zerg") {
        return "Zerg";
    }
    else {
        lv_name_of_race = CatalogFieldValueGet(c_gameCatalogRace, PlayerRace(lp_player), "Name", c_playerAny);
        lv_text = StringExternal(lv_name_of_race);
        return TextToString(lv_text);;
    }
}

