//--------------------------------------------------------------------------------------------------
// Trigger: HideScores
//--------------------------------------------------------------------------------------------------
bool gt_HideScores_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!(((gv_hideScore == EventDialogControl())))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    DialogSetVisible(gv_hiddenDialog, PlayerGroupSingle(EventPlayer()), true);
    DialogSetVisible(gv_scoreDialog, PlayerGroupSingle(EventPlayer()), false);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_HideScores_Init () {
    gt_HideScores = TriggerCreate("gt_HideScores_Func");
