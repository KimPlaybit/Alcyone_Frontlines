void lib1_gf_GameOver (int lp_losingRTSPlayer, playergroup lp_losingTeam, int lp_winningRTSPlayer, playergroup lp_winningTeam) {
    // Variable Declarations
    int lv_loopedPlayer;

    // Automatic Variable Declarations
    playergroup autoB54298AA_g;
    playergroup auto6B9A89C6_g;

    // Variable Initialization

    // Implementation
    GameOver(lp_winningRTSPlayer, c_gameOverVictory, true, true);
    GameOver(lp_losingRTSPlayer, c_gameOverDefeat, true, true);
    autoB54298AA_g = lp_winningTeam;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(autoB54298AA_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        GameOver(lv_loopedPlayer, c_gameOverVictory, true, true);
    }
    auto6B9A89C6_g = lp_losingTeam;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(auto6B9A89C6_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        GameOver(lv_loopedPlayer, c_gameOverDefeat, true, true);
    }
}

