    UnitSetState(UnitFromId(1194941189), c_unitStateSilenced, true);
    UnitSetState(UnitFromId(1917433232), c_unitStateSilenced, true);
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/E5CAA240"));
    return true;
}

