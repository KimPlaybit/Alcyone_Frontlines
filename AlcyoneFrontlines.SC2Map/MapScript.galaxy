// Trigger: VikingsIncrease
//--------------------------------------------------------------------------------------------------
bool gt_VikingsIncrease_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    TechTreeUpgradeAddLevel(15, "VikingsUpgrade", 1);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_VikingsIncrease_Init () {
    gt_VikingsIncrease = TriggerCreate("gt_VikingsIncrease_Func");
    TriggerAddEventTimePeriodic(gt_VikingsIncrease, 600.0, c_timeGame);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Melee Initialization
//--------------------------------------------------------------------------------------------------
bool gt_MeleeInitialization_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    gf_SetupSpawners();
    gf_SetupJungle();
    gf_SpawnPointsMinerals();
    lib1_gf_StartProximaGame();
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_MeleeInitialization_Init () {
    gt_MeleeInitialization = TriggerCreate("gt_MeleeInitialization_Func");
    TriggerAddEventMapInit(gt_MeleeInitialization);
}

//--------------------------------------------------------------------------------------------------
// Trigger Initialization
//--------------------------------------------------------------------------------------------------
void InitTriggers () {
    gt_ActivateXelNagaTower1_Init();
    gt_ActivateXelNagaTower2_Init();
    gt_ActivateXelNagaTower3_Init();
    gt_StartBossAi_Init();
    gt_SilenceXelNagaTower_Init();
    gt_VikingsIncrease_Init();
    gt_MeleeInitialization_Init();
}

//--------------------------------------------------------------------------------------------------
// Map Initialization
//--------------------------------------------------------------------------------------------------
void InitMap () {
    InitLibs();
    InitCustomAI();
    InitTriggers();
}
