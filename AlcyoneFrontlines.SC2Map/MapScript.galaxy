bool gt_MindControlPrevent_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_unit;
    int lv_caster;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();
    lv_caster = UnitGetOwner(EventUnit());

    // Conditions
    if (testConds) {
        if (!(((UnitGroupHasUnit(gv_revivableUnits, EventUnit()) == true)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((EventUnit() != gv_changedUnit)) {
        gv_changedUnit = EventUnit();
        UnitSetOwner(EventUnit(), EventUnitOwnerOld(), true);
    }
    else {
        gv_changedUnit = null;
    }
    return true;
}

