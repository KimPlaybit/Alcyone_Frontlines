//--------------------------------------------------------------------------------------------------
// Trigger: PsiOrb
//--------------------------------------------------------------------------------------------------
bool gt_PsiOrb_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_createdUnit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_createdUnit = EventUnitCreatedUnit();

    // Conditions
    if (testConds) {
        if (!(((UnitGetType(lv_createdUnit) == "AlarakPsiOrbMissile") == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(6.0, c_timeGame);
    if ((UnitIsAlive(lv_createdUnit) == true)) {
        UnitSetPosition(lv_createdUnit, Point(0.0, 0.0), false);
        UnitKill(lv_createdUnit);
        UnitRemove(lv_createdUnit);
    }

    return true;
}

