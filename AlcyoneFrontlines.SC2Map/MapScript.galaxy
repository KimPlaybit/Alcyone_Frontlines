bool gf_AddUpdateForWaves (string lp_upgrade, int lp_killingPlayer) {
    // Automatic Variable Declarations
    // Implementation
    if (((lp_killingPlayer == gv_rTSPlayer1) || (gf_GetAllyRTSPlayer(lp_killingPlayer) == gv_rTSPlayer1))) {
        TechTreeUpgradeAddLevel(13, lp_upgrade, 1);
    }
    else {
        TechTreeUpgradeAddLevel(14, lp_upgrade, 1);
    }
    return true;
}

bool gf_RemoveUpdateForWaves (string lp_upgrade, int lp_killingPlayer) {
    // Automatic Variable Declarations
    // Implementation
    if (((lp_killingPlayer == gv_rTSPlayer1) || (gf_GetAllyRTSPlayer(lp_killingPlayer) == gv_rTSPlayer1))) {
        TechTreeUpgradeAddLevel(13, lp_upgrade, -1);
    }
    else {
        TechTreeUpgradeAddLevel(14, lp_upgrade, -1);
    }
    return true;
}

