    lib1_gt_BanelingCreated = TriggerCreate("lib1_gt_BanelingCreated_Func");
    TriggerAddEventUnitCreated(lib1_gt_BanelingCreated, null, "MorphZerglingBanelingHero", null);
}

//--------------------------------------------------------------------------------------------------
// Trigger: BanelingExplodes
//--------------------------------------------------------------------------------------------------
bool lib1_gt_BanelingExplodes_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_unitsDmg;
    int lv_unitsShield;
    int lv_unitsHealth;
    int lv_halfHealth;
    int lv_halfShield;
    int lv_totalDmg;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unitsDmg = 100;
    lv_unitsShield = UnitGetPropertyInt(EventUnit(), c_unitPropShieldsMax, c_unitPropCurrent);
    lv_unitsHealth = UnitGetPropertyInt(EventUnit(), c_unitPropLifeMax, c_unitPropCurrent);
    lv_halfHealth = (lv_unitsHealth / 3);
    lv_halfShield = (lv_unitsShield / 3);
    lv_totalDmg = (lv_unitsShield + lv_unitsDmg);

    // Conditions
    if (testConds) {
        if (!((UnitGetType(EventUnitDamageSourceUnit()) == "BanelingHero"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitDamage(EventUnitDamageSourceUnit(), "HotSBanelingExplodeLargeSearchDamage2", EventUnit(), lv_totalDmg);
    return true;
}

