//--------------------------------------------------------------------------------------------------
// Trigger: ActivateXelNagaTower1
//--------------------------------------------------------------------------------------------------
bool gt_ActivateXelNagaTower1_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_killingPlayer;
    unit lv_tower;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_killingPlayer = UnitGetOwner(lib5A1C9904_gv_jG_KillingUnit);
    lv_tower = UnitFromId(1816851713);

    // Actions
    if (!runActions) {
        return true;
    }

    UnitSetState(lv_tower, c_unitStateSilenced, false);
    if ((lib5A1C9904_gf_GetEnemyRTSPlayer(lv_killingPlayer) == lib5A1C9904_gv_rTSPlayer1)) {
        UnitSetOwner(lv_tower, 14, true);
    }
    else {
        UnitSetOwner(lv_tower, 13, true);
    }
    UnitIssueOrder(lv_tower, OrderTargetingUnit(AbilityCommand("TowerCapture", 0), lv_tower), c_orderQueueReplace);
    Wait(180.0, c_timeGame);
    UnitSetOwner(lv_tower, 0, true);
    UnitSetState(lv_tower, c_unitStateSilenced, true);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_ActivateXelNagaTower1_Init () {
    gt_ActivateXelNagaTower1 = TriggerCreate("gt_ActivateXelNagaTower1_Func");
}

