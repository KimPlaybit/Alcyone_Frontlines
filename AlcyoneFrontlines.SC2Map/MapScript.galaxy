//--------------------------------------------------------------------------------------------------
// Trigger: MothershipCore Picked
//--------------------------------------------------------------------------------------------------
bool lib1_gt_MothershipCorePicked_Func (bool testConds, bool runActions) {
    int init_i;

    // Variable Declarations
    unit lv_createdUnit;
    unit lv_powerSource;
    playergroup[2] lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    for (init_i = 0; init_i <= 1; init_i += 1) {
        lv_player[init_i] = PlayerGroupEmpty();
    }

    // Conditions
    if (testConds) {
        if (!(((lib1_gv_playerPicked[EventPlayer()] == false) && ((lib1_gv_mothershipTeam1 == EventDialogControl()) || (lib1_gv_mothershipTeam2 == EventDialogControl()))))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UIClearMessages(PlayerGroupAll(), c_messageAreaChat);
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(EventPlayer()) + StringExternal("Param/Value/lib_1_C9C10DD3")));
    PlayerGroupAdd(lv_player[0], EventPlayer());
    if ((PlayerGetAlliance(lib1_gv_rTSPlayer1, c_allianceIdVision, EventPlayer()) == true)) {
        libNtve_gf_UnitCreateFacingPoint(1, "MothershipCoreHero", 0, EventPlayer(), PointFromId(1219627428), PlayerStartLocation(lib1_gv_rTSPlayer2));
        lv_createdUnit = UnitLastCreated();
        DialogSetVisible(lib1_gv_dialogTeam1, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
        PlayerSetAlliance(EventPlayer(), c_allianceIdPower, lib1_gv_rTSPlayer1, true);
        PlayerSetAlliance(lib1_gv_rTSPlayer1, c_allianceIdPower, EventPlayer(), true);
        PlayerSetAlliance(13, c_allianceIdPower, EventPlayer(), true);
        PlayerSetAlliance(13, c_allianceIdPower, EventPlayer(), true);
    }
    else {
        libNtve_gf_UnitCreateFacingPoint(1, "MothershipCoreHero", 0, EventPlayer(), PointFromId(1466456382), PlayerStartLocation(lib1_gv_rTSPlayer1));
        lv_createdUnit = UnitLastCreated();
        DialogSetVisible(lib1_gv_dialogTeam2, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
        PlayerSetAlliance(EventPlayer(), c_allianceIdPower, lib1_gv_rTSPlayer2, true);
        PlayerSetAlliance(lib1_gv_rTSPlayer2, c_allianceIdPower, EventPlayer(), true);
        PlayerSetAlliance(14, c_allianceIdPower, EventPlayer(), true);
    }
    UnitGroupAdd(lib1_gv_revivableUnits, lv_createdUnit);
    UnitControlGroupAddUnit(EventPlayer(), 1, lv_createdUnit);
    lib1_gv_playerPicked[EventPlayer()] = true;
    PlayerGroupAdd(lib1_gv_playersWhoPicked, EventPlayer());
    return true;
}

