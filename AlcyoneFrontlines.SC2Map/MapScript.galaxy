    // Variable Declarations
    int lv_killingPlayer;
    unit lv_killedUnit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_killingPlayer = UnitGetOwner(libNtve_gf_KillingUnit());
    lv_killedUnit = EventUnit();

    // Conditions
    if (testConds) {
        if (!(((UnitGetOwner(lv_killedUnit) == 15) && ((libNtve_gf_PlayerIsEnemy(lv_killingPlayer, gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true) || (libNtve_gf_PlayerIsEnemy(lv_killingPlayer, gv_rTSPlayer1, libNtve_ge_PlayerRelation_Neutral) == true))))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    gf_GiveResource(lv_killedUnit, gv_rTSPlayer1, lv_killingPlayer);
    gf_Respawn(lv_killedUnit, lv_killingPlayer);
    return true;
}

