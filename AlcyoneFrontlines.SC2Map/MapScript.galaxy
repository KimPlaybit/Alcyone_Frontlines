//--------------------------------------------------------------------------------------------------
// Trigger: BanelingCreated
//--------------------------------------------------------------------------------------------------
bool gt_BanelingCreated_Func (bool testConds, bool runActions) {
    // Variable Declarations
    point lv_spawnPoint;
    int lv_amountOfTicks;
    int lv_player;
    unit lv_baneling;
    unit lv_castingUnit;
    bool lv_unitdead;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_spawnPoint = PointFromId(1219627428);
    lv_player = EventPlayer();
    lv_baneling = EventUnitCreatedUnit();
    lv_castingUnit = EventUnit();

    // Conditions
    if (testConds) {
        if (!((UnitGetType(EventUnitCreatedUnit()) == "BanelingHero"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    libNtve_gf_MakeUnitInvulnerable(lv_baneling, true);
    UnitSelect(lv_baneling, UnitGetOwner(lv_castingUnit), true);
    UnitSetState(lv_castingUnit, c_unitStateHighlightable, false);
    UnitSetState(lv_castingUnit, c_unitStateCursorable, false);
    UnitSetState(lv_castingUnit, c_unitStateSelectable, false);
    UnitSetState(lv_castingUnit, c_unitStateTooltipable, false);
    UnitSetState(lv_castingUnit, c_unitStateStatusBar, false);
    UnitSetScale(lv_castingUnit, 1.0, 1.0, 1.0);
    UnitSetState(lv_castingUnit, c_unitStateSleeping, true);
    UnitSetState(lv_castingUnit, c_unitStateMoveSuppressed, false);
    libNtve_gf_MakeUnitInvulnerable(lv_castingUnit, true);
    UnitSetPosition(lv_baneling, PointWithOffset(UnitGetPosition(lv_castingUnit), 0.0, 0.0), false);
    while ((lv_unitdead == false)) {
        UnitSetState(lv_castingUnit, c_unitStateSelectable, false);
        UnitSetPosition(lv_castingUnit, PointWithOffset(UnitGetPosition(lv_baneling), 0.0, 0.0), false);
        lv_unitdead = !(UnitIsAlive(lv_baneling));
        lv_amountOfTicks = (lv_amountOfTicks + 1);
        Wait(2.0, c_timeGame);
        if ((lv_amountOfTicks == 4)) {
            lv_unitdead = true;
        }

    }
    UnitKill(lv_baneling);
    Wait(1.0, c_timeGame);
    if ((libNtve_gf_PlayerIsEnemy(lv_player, gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true)) {
        lv_spawnPoint = gf_GetSpawnPointTeam1(lv_castingUnit);
    }
    else {
        lv_spawnPoint = gf_GetSpawnPointTeam2(lv_castingUnit);
    }
    UnitSetScale(lv_castingUnit, 100.0, 100.0, 100.0);
    UnitSetPosition(lv_castingUnit, PointWithOffset(lv_spawnPoint, 0.0, 3.0), false);
    libNtve_gf_MakeUnitInvulnerable(lv_castingUnit, false);
    UnitSetState(lv_castingUnit, c_unitStateMoveSuppressed, true);
    UnitSetState(lv_castingUnit, c_unitStateHighlightable, true);
    UnitSetState(lv_castingUnit, c_unitStateCursorable, true);
    UnitSetState(lv_castingUnit, c_unitStateSelectable, true);
    UnitSetState(lv_castingUnit, c_unitStateTooltipable, true);
    UnitSetState(lv_castingUnit, c_unitStateStatusBar, true);
    UnitSetState(lv_castingUnit, c_unitStateHidden, false);
    UnitSetState(lv_castingUnit, c_unitStateSleeping, false);
    UnitSetPropertyFixed(lv_castingUnit, c_unitPropLifePercent, 100.0);
    UnitSetPropertyFixed(lv_castingUnit, c_unitPropShieldsPercent, 100.0);
    CameraPan(UnitGetOwner(lv_castingUnit), lv_spawnPoint, 0.0, -1, 10.0, false);
    UnitClearSelection(UnitGetOwner(lv_castingUnit));
    UnitSelect(lv_castingUnit, UnitGetOwner(lv_castingUnit), true);
    return true;
}

