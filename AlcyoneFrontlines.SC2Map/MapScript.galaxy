void gf_SetupTeams1 () {
    // Variable Declarations
    int lv_loopedPlayer;
    int lv_loopedPlayer2;

    // Automatic Variable Declarations
    playergroup auto71BACAB5_g;
    playergroup auto02950358_g;

    // Variable Initialization
    lv_loopedPlayer = 1;
    lv_loopedPlayer2 = 1;

    // Implementation
    libNtve_gf_SetAlliance(13, gv_rTSPlayer1, libNtve_ge_AllianceSetting_NeutralWithSharedVision);
    libNtve_gf_SetAlliance(14, gv_rTSPlayer1, libNtve_ge_AllianceSetting_Enemy);
    auto71BACAB5_g = gv_soldierPlayers1;
    lv_loopedPlayer = -1;
    while (true) {
        lv_loopedPlayer = PlayerGroupNextPlayer(auto71BACAB5_g, lv_loopedPlayer);
        if (lv_loopedPlayer < 0) { break; }
        libNtve_gf_SetAlliance(lv_loopedPlayer, gv_rTSPlayer1, libNtve_ge_AllianceSetting_AllyWithSharedVision);
        auto02950358_g = gv_soldierPlayers1;
        lv_loopedPlayer2 = -1;
        while (true) {
            lv_loopedPlayer2 = PlayerGroupNextPlayer(auto02950358_g, lv_loopedPlayer2);
            if (lv_loopedPlayer2 < 0) { break; }
            libNtve_gf_SetAlliance(lv_loopedPlayer, lv_loopedPlayer2, libNtve_ge_AllianceSetting_AllyWithSharedVision);
        }
        libNtve_gf_SetAlliance(13, lv_loopedPlayer, libNtve_ge_AllianceSetting_NeutralWithSharedVision);
        libNtve_gf_SetAlliance(14, lv_loopedPlayer, libNtve_ge_AllianceSetting_Enemy);
        CameraPan(lv_loopedPlayer, PointFromId(1219627428), 0.0, -1, 10.0, false);
    }
}

