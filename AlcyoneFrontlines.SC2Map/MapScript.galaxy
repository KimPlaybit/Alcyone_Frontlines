//--------------------------------------------------------------------------------------------------
// Trigger: Controller
//--------------------------------------------------------------------------------------------------
bool gt_Controller_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_offsetVeterancy;
    unit lv_defendSpawner;
    point lv_startPos;
    point lv_hostilePoint;
    int lv_veteranLevel;
    int lv_player;
    unit lv_unit;
    unitgroup lv_unitGroup;
    int lv_state;
    point lv_currentPosition;
    point lv_lastPosition;
    int lv_stuckCounter;
    const int lv_maxCounter = 150;
    int lv_commit;
    int lv_allyRTSPlayer;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_veteranLevel = 1;
    lv_player = gv_playerToStart;
    lv_unit = UnitGroupUnit(gv_unitGroup, 1);
    lv_unitGroup = gv_unitGroup;
    lv_state = 99;
    lv_allyRTSPlayer = gf_GetAllyRTSPlayer(lv_player);

    // Actions
    if (!runActions) {
        return true;
    }

    lv_startPos = gf_GetStartLocation(lv_player);
    AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
    AIAttackWaveSend(lv_player, 0, false);
    if (((UnitGetType(lv_unit) == "SpectreHero"))) {
        lv_offsetVeterancy = -2;
    }

    while (true) {
        lv_currentPosition = UnitGroupCenterOfGroup(lv_unitGroup);
        lv_veteranLevel = UnitXPGetCurrentLevel(lv_unit, null);
        lv_hostilePoint = gf_AttackPointHostiles(lv_startPos, lv_currentPosition, lv_veteranLevel, lv_offsetVeterancy);
        if ((((gf_IsProtoss(lv_allyRTSPlayer) == true) && (UnitGetPropertyFixed(lv_unit, c_unitPropShieldsPercent, c_unitPropCurrent) < 5.0)) || ((gf_IsProtoss(lv_allyRTSPlayer) == false) && (UnitGetPropertyFixed(lv_unit, c_unitPropLifePercent, c_unitPropCurrent) < 30.0)) || ((lv_state == 1) && (UnitGetPropertyFixed(lv_unit, c_unitPropLifePercent, c_unitPropCurrent) < 70.0)) || ((lv_state == 1) && (UnitGetPropertyFixed(lv_unit, c_unitPropShieldsMax, c_unitPropCurrent) < 0.0) && (UnitGetPropertyFixed(lv_unit, c_unitPropShieldsPercent, c_unitPropCurrent) < 50.0)))) {
            if ((lv_state != 1)) {
                AISetDifficulty(lv_player, c_diffNormalTargetPrio, true);
                AISetDifficulty(lv_player, c_diffWaveLeashing, true);
                AISetDifficulty(lv_player, c_diffWaveAvoidDanger, true);
                AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/4A57B1D1")));
                AIAttackWaveSetTargetPoint(lv_player, lv_startPos);
                AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                AIAttackWaveSend(lv_player, 0, false);
                UnitIssueOrder(lv_unit, OrderTargetingPoint(AbilityCommand("move", 0), UnitGetPosition(gf_FindHealspot(lv_unit))), c_orderQueueReplace);
                lv_state = 1;
                lv_stuckCounter = 0;
            }
            else {
                if ((lv_stuckCounter >= lv_maxCounter)) {
                    lv_state = 99;
                    lv_lastPosition = null;
                    lv_stuckCounter = 0;
                }
                else {
                    lv_stuckCounter = (lv_stuckCounter + 1);
                }
            }
        }
        else {
            lv_defendSpawner = gf_SpawnersBeingAttacked(lv_unit, lv_player);
            if (((lv_defendSpawner != null))) {
                if ((lv_state != 3)) {
                    AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                    AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                    AIAttackWaveSetTargetRegion(lv_player, RegionCircle(UnitGetPosition(lv_unit), 3.0), 1);
                    AISetDifficulty(lv_player, c_diffNormalTargetPrio, false);
                    AISetDifficulty(lv_player, c_diffWaveLeashing, false);
                    AISetDifficulty(lv_player, c_diffWaveAvoidDanger, false);
                    libNtve_gf_AICast(lv_unit, OrderTargetingPoint(AbilityCommand("move", 0), UnitGetPosition(lv_defendSpawner)));
                    AIAttackWaveSend(lv_player, 0, false);
                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + (StringExternal("Param/Value/970F4C5F") + StringExternal(libNtve_gf_ConvertPointToString(UnitGroupCenterOfGroup(libNtve_gf_ConvertUnitToUnitGroup(lv_defendSpawner)))))));
                    lv_lastPosition = lv_hostilePoint;
                    lv_stuckCounter = 0;
                    lv_state = 3;
                    if ((UnitGetType(lv_unit) == "DragoonHero")) {
                        UnitIssueOrder(lv_unit, OrderTargetingUnit(AbilityCommand("ArtanisWormholeTransit", 0), lv_defendSpawner), c_orderQueueReplace);
                    }

                }
                else {
                    if ((lv_stuckCounter >= lv_maxCounter)) {
                        lv_state = 99;
                        lv_lastPosition = null;
                        lv_stuckCounter = 0;
                    }
                    else {
                        lv_stuckCounter = (lv_stuckCounter + 1);
                    }
                }
            }
            else {
                if ((lv_hostilePoint != null)) {
                    if ((((lv_lastPosition == null) || (DistanceBetweenPoints(lv_lastPosition, lv_hostilePoint) >= 5.0))) && (lv_state != 2)) {
                        AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                        AISetDifficulty(lv_player, c_diffNormalTargetPrio, true);
                        AISetDifficulty(lv_player, c_diffWaveLeashing, true);
                        AISetDifficulty(lv_player, c_diffWaveAvoidDanger, true);
                        AIAttackWaveSetTargetUnitGroup(lv_player, UnitGroup(null, 15, RegionCircle(lv_hostilePoint, 5.0), UnitFilter(0, 0, (1 << c_targetFilterPlayer) | (1 << c_targetFilterAlly) | (1 << c_targetFilterNeutral) | (1 << c_targetFilterStructure) | (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0));
                        AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                        AIAttackWaveSend(lv_player, 0, false);
                        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + (StringExternal("Param/Value/E72E4A77") + StringExternal(libNtve_gf_ConvertPointToString(lv_hostilePoint)))));
                        lv_lastPosition = lv_hostilePoint;
                        lv_stuckCounter = 0;
                        lv_state = 2;
                    }
                    else {
                        if ((lv_stuckCounter >= lv_maxCounter)) {
                            lv_state = 99;
                            lv_lastPosition = null;
                            lv_stuckCounter = 0;
                        }
                        else {
                            lv_stuckCounter = (lv_stuckCounter + 1);
                        }
                    }
                }
                else {
                    if ((lv_state != 0)) {
                        AIAttackWaveCancel(AIWaveGet(lv_player, 0));
                        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/7FEA5A0F")));
                        if (((UnitGetType(lv_unit) == "ZerglingHero") || (UnitGetType(lv_unit) == "AvengerHero") || (UnitGetType(lv_unit) == "SpectreHero"))) {
                            AIAttackWaveSetTargetUnitGroup(lv_player, UnitGroupAlliance(gf_GetEnemyRTSPlayer(lv_player), c_unitAllianceAllyExcludeSelf, RegionEntireMap(), UnitFilter(0, 0, (1 << c_targetFilterPlayer) | (1 << c_targetFilterNeutral) | (1 << c_targetFilterEnemy) | (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0));
                        }
                        else {
                            AIAttackWaveSetTargetMelee(lv_player);
                        }
                        AIAttackWaveUseGroup(lv_player, libNtve_gf_ConvertUnitToUnitGroup(lv_unit));
                        AIAttackWaveSend(lv_player, 0, false);
                        AISetDifficulty(lv_player, c_diffNormalTargetPrio, true);
                        AISetDifficulty(lv_player, c_diffWaveLeashing, true);
                        AISetDifficulty(lv_player, c_diffWaveAvoidDanger, true);
                        lv_state = 0;
                        lv_stuckCounter = 0;
                    }
                    else {
                        if ((lv_stuckCounter >= lv_maxCounter)) {
                            lv_state = 99;
                            lv_lastPosition = null;
                            lv_stuckCounter = 0;
                        }
                        else {
                            lv_stuckCounter = (lv_stuckCounter + 1);
                        }
                    }
                }
            }
        }
        Wait(0.1, c_timeGame);
    }
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(lv_player) + StringExternal("Param/Value/8ECB9806")));
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_Controller_Init () {
    gt_Controller = TriggerCreate("gt_Controller_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Firebat Soldier Picked
//--------------------------------------------------------------------------------------------------
bool gt_FirebatSoldierPicked_Func (bool testConds, bool runActions) {
    int init_i;

    // Variable Declarations
    playergroup[2] lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    for (init_i = 0; init_i <= 1; init_i += 1) {
        lv_player[init_i] = PlayerGroupEmpty();
    }

    // Conditions
    if (testConds) {
        if (!(((gv_playerPicked[EventPlayer()] == false) && ((gv_firebatTeam1 == EventDialogControl()) || (gv_firebatTeam2 == EventDialogControl()))))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (PlayerName(EventPlayer()) + StringExternal("Param/Value/D7389F58")));
    PlayerGroupAdd(lv_player[0], EventPlayer());
    if ((PlayerGetAlliance(gv_rTSPlayer1, c_allianceIdVision, EventPlayer()) == true)) {
        libNtve_gf_UnitCreateFacingPoint(1, "FirebatHero", 0, EventPlayer(), PointFromId(1219627428), PlayerStartLocation(gv_rTSPlayer2));
        DialogSetVisible(gv_dialogTeam1, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    else {
        libNtve_gf_UnitCreateFacingPoint(1, "FirebatHero", 0, EventPlayer(), PointFromId(1466456382), PlayerStartLocation(gv_rTSPlayer1));
        DialogSetVisible(gv_dialogTeam2, lv_player[0], false);
        UnitSelect(UnitLastCreated(), EventPlayer(), true);
    }
    UnitGroupAdd(gv_revivableUnits, UnitLastCreated());
    UnitControlGroupAddUnit(EventPlayer(), 1, UnitLastCreated());
    gv_playerPicked[EventPlayer()] = true;
    return true;
}

