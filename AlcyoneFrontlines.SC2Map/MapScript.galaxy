//--------------------------------------------------------------------------------------------------
// Trigger: Healburst
//--------------------------------------------------------------------------------------------------
bool gt_Healburst_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_amountOftimes;
    int lv_extraIndex;
    unit lv_victim;
    unit lv_caster;
    int lv_increase;

    // Automatic Variable Declarations
    const int auto620152D2_ae = 5;
    const int auto620152D2_ai = 1;
    int autoE906E8D4_ae;
    const int autoE906E8D4_ai = 1;

    // Variable Initialization
    lv_victim = EventUnitTargetUnit();
    lv_caster = EventUnit();
    lv_increase = ((UnitXPGetCurrentLevel(lv_caster, "ZergLevels") * 20) / 10);

    // Actions
    if (!runActions) {
        return true;
    }

    lv_amountOftimes = 1;
    for ( ; ( (auto620152D2_ai >= 0 && lv_amountOftimes <= auto620152D2_ae) || (auto620152D2_ai < 0 && lv_amountOftimes >= auto620152D2_ae) ) ; lv_amountOftimes += auto620152D2_ai ) {
        autoE906E8D4_ae = lv_increase;
        lv_extraIndex = 1;
        for ( ; ( (autoE906E8D4_ai >= 0 && lv_extraIndex <= autoE906E8D4_ae) || (autoE906E8D4_ai < 0 && lv_extraIndex >= autoE906E8D4_ae) ) ; lv_extraIndex += autoE906E8D4_ai ) {
            UnitCreateEffectUnit(lv_caster, "QueenHeal2", lv_victim);
        }
        Wait(0.5, c_timeGame);
    }
    return true;
}

