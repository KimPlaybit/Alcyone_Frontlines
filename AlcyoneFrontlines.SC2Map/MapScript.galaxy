    // Implementation
    if ((libNtve_gf_PlayerIsEnemy(lp_player, gv_rTSPlayer1, libNtve_ge_PlayerRelation_Ally) == true)) {
        UnitGroupAdd(lv_spawners, gv_team1Spawner1);
        UnitGroupAdd(lv_spawners, gv_team1Spawner2);
        UnitGroupAdd(lv_spawners, gv_team1Spawner3);
    }
    else {
        UnitGroupAdd(lv_spawners, gv_team2Spawner1);
        UnitGroupAdd(lv_spawners, gv_team2Spawner2);
        UnitGroupAdd(lv_spawners, gv_team2Spawner3);
    }
    return lv_spawners;
}

unit gf_SpawnersBeingAttacked (unit lp_heroUnit, int lp_player) {
    // Variable Declarations
    unit lv_unit;
    unit lv_spawner;
    unitgroup lv_spawners;

    // Automatic Variable Declarations
    unitgroup auto1473E723_g;
    int auto1473E723_u;

    // Variable Initialization
    lv_spawners = gf_GetSpawners(lp_player);

    // Implementation
    auto1473E723_g = lv_spawners;
    auto1473E723_u = UnitGroupCount(auto1473E723_g, c_unitCountAll);
    for (;; auto1473E723_u -= 1) {
        lv_unit = UnitGroupUnitFromEnd(auto1473E723_g, auto1473E723_u);
        if (lv_unit == null) { break; }
        if ((libNtve_gf_UnitGroupIsDead(libNtve_gf_ConvertUnitToUnitGroup(lv_unit)) == false)) {
            lv_spawner = gf_FindEnemyHero(lv_unit);
            if ((((lv_spawner != null) && (DistanceBetweenPoints(UnitGetPosition(lp_heroUnit), UnitGetPosition(lv_spawner)) <= 40.0)) || ((lv_spawner != null) && (UnitAbilityGetCooldown(lp_heroUnit, "ArtanisWormholeTransit", "Abil/ArtanisWormholeTransit") <= 0.0) && (UnitGetType(lp_heroUnit) == "DragoonHero")) || ((lv_spawner != null) && (UnitGetType(lp_heroUnit) == "CorsairHero")))) {
                return lv_spawner;
            }

        }

    }
    return null;
}

point gf_ClosestPoint (point lp_lastPoint, point lp_unitPoint, unitgroup lp_pointToAttack, point lp_startPoint) {
    // Automatic Variable Declarations
    // Implementation
    if (((lp_lastPoint == null) && (libNtve_gf_UnitGroupIsDead(lp_pointToAttack) == false) && (DistanceBetweenPoints(lp_startPoint, UnitGroupCenterOfGroup(lp_pointToAttack)) < 100.0))) {
        return UnitGroupCenterOfGroup(lp_pointToAttack);
    }

    if (((libNtve_gf_UnitGroupIsDead(lp_pointToAttack) == true))) {
        return lp_lastPoint;
    }

    if ((((lp_lastPoint == null) || (DistanceBetweenPoints(lp_unitPoint, UnitGroupCenterOfGroup(lp_pointToAttack)) < DistanceBetweenPoints(lp_unitPoint, lp_lastPoint))) && (DistanceBetweenPoints(lp_unitPoint, UnitGroupCenterOfGroup(lp_pointToAttack)) < 40.0))) {
        return UnitGroupCenterOfGroup(lp_pointToAttack);
    }
    else {
        return lp_lastPoint;
    }
}

point gf_AttackPointHostiles (point lp_startPos, point lp_currentPosition, int lp_veteranLevel, int lp_offsetVeterancy) {
    // Variable Declarations
    point lv_point;

    // Automatic Variable Declarations
    // Variable Initialization

    // Implementation
    if ((((libNtve_gf_UnitGroupIsDead(gv_zerglingExpansionTeam1) == false) || (libNtve_gf_UnitGroupIsDead(gv_zerglingExpansionTeam2) == false)) && ((lp_veteranLevel + lp_offsetVeterancy) >= 1))) {
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_zerglingExpansionTeam1, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_zerglingExpansionTeam2, lp_startPos);
    }

    if ((((libNtve_gf_UnitGroupIsDead(gv_zergling_1) == false) || (libNtve_gf_UnitGroupIsDead(gv_zergling_2) == false)) && ((lp_veteranLevel + lp_offsetVeterancy) >= 2))) {
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_zergling_1, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_zergling_2, lp_startPos);
    }

    if ((((libNtve_gf_UnitGroupIsDead(gv_terranExpansionTeam1) == false) || (libNtve_gf_UnitGroupIsDead(gv_terranExpansionTeam2) == false) || (libNtve_gf_UnitGroupIsDead(gv_topExpansionTeam1) == false) || (libNtve_gf_UnitGroupIsDead(gv_topExpansionTeam2) == false) || (libNtve_gf_UnitGroupIsDead(gv_vikings_1) == false) || (libNtve_gf_UnitGroupIsDead(gv_vikings_2) == false) || (libNtve_gf_UnitGroupIsDead(gv_vikings_3) == false)) && ((lp_veteranLevel + lp_offsetVeterancy) >= 3))) {
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_terranExpansionTeam1, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_terranExpansionTeam2, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_topExpansionTeam2, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_topExpansionTeam1, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_vikings_1, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_vikings_2, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_vikings_3, lp_startPos);
    }

    if ((((libNtve_gf_UnitGroupIsDead(gv_zergExpansionTeam1) == false) || (libNtve_gf_UnitGroupIsDead(gv_zergExpansionTeam2) == false)) && ((lp_veteranLevel + lp_offsetVeterancy) >= 4))) {
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_zergExpansionTeam1, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_zergExpansionTeam2, lp_startPos);
    }

    if ((((libNtve_gf_UnitGroupIsDead(gv_hydralisk_1) == false) || (libNtve_gf_UnitGroupIsDead(gv_hydralisk_2) == false) || (libNtve_gf_UnitGroupIsDead(gv_marines_1) == false) || (libNtve_gf_UnitGroupIsDead(gv_marines_2) == false) || (libNtve_gf_UnitGroupIsDead(gv_topExpansion) == false)) && (lp_veteranLevel >= 4))) {
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_hydralisk_1, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_hydralisk_2, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_topExpansion, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_marines_1, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_marines_2, lp_startPos);
    }

    if ((((libNtve_gf_UnitGroupIsDead(gv_botExpansion) == false) || (libNtve_gf_UnitGroupIsDead(gv_midExpansion) == false)) && ((lp_veteranLevel + lp_offsetVeterancy) >= 5))) {
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_botExpansion, lp_startPos);
        lv_point = gf_ClosestPoint(lv_point, lp_currentPosition, gv_midExpansion, lp_startPos);
    }

    return lv_point;
}

void gf_StartAi (point lp_startPos, int lp_player) {
    // Automatic Variable Declarations
    // Implementation
        int diff = AIPlayerDifficulty(lp_player);
        point targDPoint;
        point targOPoint;
        wavetarget targD;
        wavetarget targO;
        int attackersLimit;
    if ((PlayerType(lp_player) == c_playerTypeComputer)) {
        	AIStart(lp_player, false, DifficultyAPM(diff));
            if (diff == c_skirChInsane) {
                // insane starts at 1.2 and ramps to 2.0
                AIHarvestBonus(lp_player, 1.2);
            }
            
            AISetDifficulty(lp_player, c_diffRepairDamage, true);
            AISetDifficulty(lp_player, c_diffOptimizeGas, true);
            AISetDifficulty(lp_player, c_diffDefendWithPeons, false);
            AISetDifficulty(lp_player, c_diffEnableDangerMap, true);
            AISetDifficulty(lp_player, c_diffNormalTargetPrio, true);
            AISetDifficulty(lp_player, c_diffAllowResourceReq, true);
            AISetDifficulty(lp_player, c_diffAdvancedRetreatLogic, true);
            AISetDifficulty(lp_player, c_diffSupportsBeacons, true);
            AISetDifficulty(lp_player, c_diffAutoBuildPrereqs, true);
            AISetDifficulty(lp_player, c_diffAllowBuildInDanger, true);
            AISetDifficulty(lp_player, c_diffTimeoutMakeRequests, true);
            AISetDifficulty(lp_player, c_diffSetRallyPoints, true);
            AISetDifficulty(lp_player, c_diffAllowLongDistanceMining, true);
            AISetDifficulty(lp_player, c_diffBalancePeonsAcrossBases, true);
            AISetDifficulty(lp_player, c_diffWaveLeashing, true);
            AISetDifficulty(lp_player, c_diffAutoTransport, true);
            AISetDifficulty(lp_player, c_diffAllowTransportGather, true);
            AISetDifficulty(lp_player, c_diffAvoidMindControlled, true);
            AISetDifficulty(lp_player, c_diffNormalVision,     (diff < c_skirChVision));       // normal vision, unless cheating
            AISetDifficulty(lp_player, c_diffLimitAPM,         (diff < c_skirHard_VH));        // limit all apm on lower difficulties
            AISetDifficulty(lp_player, c_diffLimitAPMCombat,   (diff < c_skirVeryHard));       // limit combat apm below elite
            AISetDifficulty(lp_player, c_diffSplitAttacking,   (diff < c_skirVeryHard));       // split attacks below elite
            AISetDifficulty(lp_player, c_diffSpotChangelings,   (diff >= c_skirVeryHard));
            AISetDifficulty(lp_player, c_diffWaveAvoidDanger,   (diff >= c_skirHard));
            AISetDifficulty(lp_player, c_diffEarlyDefenseScout, (diff >= c_skirHard));
            AISetDifficulty(lp_player, c_diffUseExtraScouts,    (diff >= c_skirHard));
            AISetDifficulty(lp_player, c_diffHoldAtIdleChokes,  (diff >= c_skirHard));
            AISetDifficulty(lp_player, c_diffPressForward,      (diff >= c_skirMedium));
            AISetDifficulty(lp_player, c_diffFleeWorkers,       (diff >= c_skirMedium));
            AISetDifficulty(lp_player, c_diffFleeDanger,        (diff >= c_skirMedium));
            AISetDifficulty(lp_player, c_diffTargetSpawners,    (diff >= c_skirMedium));
            AISetDifficulty(lp_player, c_diffAllowKiting,       (diff >= c_skirHard_VH));
            AISetDifficulty(lp_player, c_diffDelayAdvTargetting,(diff <= c_skirMedium));       // deliberately target interceptors/locusts on medium and below
            AISetDifficulty(lp_player, c_diffAutoLoadBunkers, false);
            AISetDifficulty(lp_player, c_diffEarlyGameRepair, false);
            AISetFlag(lp_player, e_flagsAllowRetreat, (diff >= c_skirMed_Hard));
            AISetFlag(lp_player, e_flagsAllowDropAttack, (diff >= c_skirChMoney));     // only going to allow resource cheating AIs to drop, it's rarely successful and often costs resources
            AISetFlag(lp_player, e_flagsRunScared, false);
            AISetFlag(lp_player, e_flagsLateScout, false);
            AISetFlag(lp_player, e_flagsClearObs, false);
            AIDeclareTown(lp_player, c_townOne, lp_startPos);
            AISetMainTown(lp_player, c_townOne);
            AIHarvest(lp_player, c_townOne);
            AISetAllStates(lp_player, 1);
            
            targDPoint = AIWaveTargetGatherDPoint(lp_player, c_townMain);
            targOPoint = AIWaveTargetGatherOPoint(lp_player, c_townMain);
            targD = AIWaveTargetGatherD(lp_player, c_townMain);
            targO = AIWaveTargetGatherMelee(lp_player);    
            AIWaveSet(lp_player, c_waveMain,       AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveAttack,     AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveDivert1,    AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveDivert2,    AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveClearObs,   AIWaveCreate(AIWaveInfoCreate(), lp_player, targOPoint));
            AIWaveSet(lp_player, c_waveHome,       AIWaveCreate(AIWaveInfoCreate(), lp_player, targDPoint));
            AIWaveSet(lp_player, c_waveDefend,     AIWaveCreate(AIWaveInfoCreate(), lp_player, targDPoint));
            AIWaveSetType(AIWaveGet(lp_player, c_waveMain),     c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveAttack),   c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveDivert1),  c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveDivert2),  c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveClearObs), c_waveStateIdle, targO);
            AIWaveSetType(AIWaveGet(lp_player, c_waveHome),     c_waveStateIdle, targD);
            AIWaveSetType(AIWaveGet(lp_player, c_waveDefend),   c_waveStateIdle, targD);
            attackersLimit = 1 << diff;
            AISetMaxBestAttackersLimit(lp_player, attackersLimit);
            AITransportIgnore(lp_player, "VikingAssault");
            AITransportSetPanic(lp_player, 0.6);
            AITransportSetReturn(lp_player, targDPoint);
            AISetDefenseRadii(lp_player, 15.0, 10.0, 12.0);
            AISetNumScouts(lp_player, 1);
            AIEarlyDefenseEnable(lp_player, false, false);
            if (diff < c_skirChVision) {
                // need early defense scouting if not cheating vision
                AIEarlyDefenseProps(lp_player, 30, 20, 30);
            } else {
                // let cheating AIs defend against further threats
                AIEarlyDefenseProps(lp_player, 35, 35, 45);
                if (!AIHasHumanAlly(lp_player)) {
                    AISetNumScouts(lp_player, 0);
                }
            }
            AIScout(lp_player);
            AISetUserInt(lp_player, c_numGroundStartLocs, AIGetGroundStartLocs(lp_startPos));
            AISetUserInt(lp_player, c_numAirStartLocs, AIGetAirStartLocs(lp_startPos));
            AISetUserInt(lp_player, c_delayNextAttack, 0);
            AISpecifiedHealers(lp_player);
            AISetDefaultCombatFlags(lp_player, true);
    }

}

void gf_StartSoldierAI (point lp_startPos, int lp_player, unit lp_wave) {
    // Variable Declarations
    wavetarget lv_targO;
    wavetarget lv_targD;
    point lv_targOPoint;
    point lv_targDPoint;
    int lv_diff;
    waveinfo lv_heroWave;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_heroWave = AIWaveInfoCreate();

    // Implementation
    AIStart(lp_player, true, 200);
    AISetDifficulty(lp_player, c_diffEnableDangerMap, true);
    AISetDifficulty(lp_player, c_diffNormalTargetPrio, true);
    AISetDifficulty(lp_player, c_diffWaveLeashing, true);
    AISetDifficulty(lp_player, c_diffWaveAvoidDanger, true);
    AISetDifficulty(lp_player, c_diffSplitAttacking, true);
    AISetDifficulty(lp_player, c_diffFleeDamage, true);
    AISetDifficulty(lp_player, c_diffHoldAtIdleChokes, true);
    AISetDifficulty(lp_player, c_diffAllowKiting, true);
    AISetDifficulty(lp_player, c_diffAdvancedRetreatLogic, true);
    AISetFlag(lp_player, e_flagsAllowRetreat, true);
    AIEarlyDefenseEnable(lp_player, true, true);
    AIReqCountAsBuiltObject(lp_player, UnitGetType(lp_wave));
    AIAttackWaveUseUnit(lp_player, lp_wave);
    AIEvalSetCustomIndex((10 + (UnitXPGetCurrentLevel(lp_wave, null) * 3)));
    AIDeclareTown(lp_player, -1, lp_startPos);
    gv_playerToStart = lp_player;
    gv_unitGroup = libNtve_gf_ConvertUnitToUnitGroup(lp_wave);
    TriggerExecute(gt_Controller, false, false);
}

void gf_HeroSpells (int lp_player, unit lp_unit) {
    // Automatic Variable Declarations
    // Implementation
    if ((UnitGetType(lp_unit) == "CorsairHero")) {
        gf_Corsair(lp_player, lp_unit);
    }

}

//--------------------------------------------------------------------------------------------------
// Trigger: Melee Initialization
//--------------------------------------------------------------------------------------------------
bool gt_MeleeInitialization_Func (bool testConds, bool runActions) {
    // Variable Declarations
    bool lv_waves;
    string lv_raceName;
    point lv_startpos1;
    point lv_startpos2;
    point lv_offsetplayer1;
    point lv_offsetplayer2;
    bool lv_raceCheck;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_waves = gf_GetWaveStatus();;
    lv_raceName = "";
    lv_startpos1 = PointFromId(1219627428);
    lv_startpos2 = PointFromId(1466456382);
    lv_offsetplayer1 = PointWithOffset(PointFromId(1219627428), 3.0, 3.0);
    lv_offsetplayer2 = PointWithOffset(PointFromId(1466456382), -2.0, -3.0);

    // Actions
    if (!runActions) {
        return true;
    }

    if ((gf_IsSurvival() == true)) {
        if ((gf_WithRTSPlayer() == true)) {
            gv_rTSPlayer1 = PlayerGroupPlayer(GameAttributePlayersForTeam(1), 1);
            gv_soldierPlayers1 = GameAttributePlayersForTeam(2);
            MeleeInitUnitsForPlayer(gv_rTSPlayer1, PlayerRace(gv_rTSPlayer1), PointFromId(1219627428));
            gf_SpawnDefenceTower(gv_rTSPlayer1, 13, lv_offsetplayer1, lv_startpos2);
        }
        else {
            gv_rTSPlayer1 = PlayerGroupPlayer(GameAttributePlayersForTeam(1), 1);
            gv_soldierPlayers1 = GameAttributePlayersForTeam(2);
            PlayerGroupAdd(gv_soldierPlayers1, gv_rTSPlayer1);
        }
    }
    else {
        gv_soldierPlayers1 = GameAttributePlayersForTeam(3);
        gv_soldierPlayers2 = GameAttributePlayersForTeam(4);
        gv_rTSPlayer1 = PlayerGroupPlayer(GameAttributePlayersForTeam(1), 1);
        gv_rTSPlayer2 = PlayerGroupPlayer(GameAttributePlayersForTeam(2), 1);
        MeleeInitUnitsForPlayer(gv_rTSPlayer1, PlayerRace(gv_rTSPlayer1), PointFromId(1219627428));
        gf_SpawnDefenceTower(gv_rTSPlayer1, 13, lv_offsetplayer1, lv_startpos2);
        MeleeInitUnitsForPlayer(gv_rTSPlayer2, PlayerRace(gv_rTSPlayer2), PointFromId(1466456382));
        gf_SpawnDefenceTower(gv_rTSPlayer2, 14, lv_offsetplayer2, lv_startpos1);
    }
    gf_SetupTeams1();
    gf_SetupTeams2();
    MeleeInitResourcesForPlayer(gv_rTSPlayer1, PlayerRace(gv_rTSPlayer1));
    MeleeInitResourcesForPlayer(gv_rTSPlayer2, PlayerRace(gv_rTSPlayer2));
    CameraPan(gv_rTSPlayer1, PointFromId(1219627428), 0.0, -1, 10.0, false);
    CameraPan(gv_rTSPlayer2, PointFromId(1466456382), 0.0, -1, 10.0, false);
    gf_StartAi(lv_startpos1, gv_rTSPlayer1);
    gf_StartAi(lv_startpos2, gv_rTSPlayer2);
    Wait(0.5, c_timeGame);
    gf_SpawnPointsMinerals();
    gf_Scores();
    gf_SoldierSelectionTeam1();
    gf_SoldierSelectionTeam2();
    Wait(0.5, c_timeGame);
    UISetAlertTypeVisible(PlayerGroupAll(), "AttackUnitAlly_Prot", false);
    UISetAlertTypeVisible(PlayerGroupAll(), "AttackUnitAlly_Zerg", false);
    UISetAlertTypeVisible(PlayerGroupAll(), "AttackUnitAlly_Terr", false);
    if ((lv_waves == true)) {
        lv_raceCheck = gf_IsTerran(gv_rTSPlayer1);;
        if ((lv_raceCheck == true)) {
            gv_team1SpawnUnit = "Marine";
            gv_amountTeam1 = 4;
            UnitCreate(1, "Bunker2", 0, 13, PointFromId(221368982), 270.0);
            gv_team1Spawner1 = UnitLastCreated();
            UnitCreate(1, "Bunker2", 0, 13, RegionGetCenter(RegionFromId(12)), 270.0);
            gv_team1Spawner2 = UnitLastCreated();
            UnitCreate(1, "Bunker2", 0, 13, RegionGetCenter(RegionFromId(13)), 270.0);
            gv_team1Spawner3 = UnitLastCreated();
        }

        lv_raceCheck = gf_IsZerg(gv_rTSPlayer1);;
        if ((lv_raceCheck == true)) {
            gv_team1SpawnUnit = "Zergling2";
            gv_amountTeam1 = 6;
            UnitCreate(1, "NydusCanal2", 0, 13, PointFromId(221368982), 270.0);
            gv_team1Spawner1 = UnitLastCreated();
            UnitCreate(1, "NydusCanal2", 0, 13, RegionGetCenter(RegionFromId(12)), 270.0);
            gv_team1Spawner2 = UnitLastCreated();
            UnitCreate(1, "NydusCanal2", 0, 13, RegionGetCenter(RegionFromId(13)), 270.0);
            gv_team1Spawner3 = UnitLastCreated();
        }

        lv_raceCheck = gf_IsProtoss(gv_rTSPlayer1);;
        if ((lv_raceCheck == true)) {
            gv_team1SpawnUnit = "Zealot2";
            gv_amountTeam1 = 2;
            UnitCreate(1, "VoidPylon", 0, 13, PointFromId(221368982), 270.0);
            gv_team1Spawner1 = UnitLastCreated();
            UnitCreate(1, "VoidPylon", 0, 13, RegionGetCenter(RegionFromId(12)), 270.0);
            gv_team1Spawner2 = UnitLastCreated();
            UnitCreate(1, "VoidPylon", 0, 13, RegionGetCenter(RegionFromId(13)), 270.0);
            gv_team1Spawner3 = UnitLastCreated();
        }

        lv_raceCheck = gf_IsNonKnownRace(gv_rTSPlayer1);;
        if ((lv_raceCheck == false)) {
            gv_team1SpawnUnit = "Zealot2";
            gv_amountTeam1 = 2;
            UnitCreate(1, "VoidPylon", 0, 13, PointFromId(221368982), 270.0);
            gv_team1Spawner1 = UnitLastCreated();
            UnitCreate(1, "VoidPylon", 0, 13, RegionGetCenter(RegionFromId(12)), 270.0);
            gv_team1Spawner2 = UnitLastCreated();
            UnitCreate(1, "VoidPylon", 0, 13, RegionGetCenter(RegionFromId(13)), 270.0);
            gv_team1Spawner3 = UnitLastCreated();
        }

        lv_raceCheck = false;
        lv_raceCheck = gf_IsProtoss(gv_rTSPlayer2);;
        if ((lv_raceCheck == true)) {
            gv_team2SpawnUnit = "Zealot2";
            gv_amountTeam2 = 2;
            UnitCreate(1, "VoidPylon", 0, 14, PointFromId(1320118314), 270.0);
            gv_team2Spawner1 = UnitLastCreated();
            UnitCreate(1, "VoidPylon", 0, 14, RegionGetCenter(RegionFromId(14)), 270.0);
            gv_team2Spawner2 = UnitLastCreated();
            UnitCreate(1, "VoidPylon", 0, 14, RegionGetCenter(RegionFromId(15)), 270.0);
            gv_team2Spawner3 = UnitLastCreated();
        }

        lv_raceCheck = gf_IsTerran(gv_rTSPlayer2);;
        if ((lv_raceCheck == true)) {
            gv_team2SpawnUnit = "Marine";
            gv_amountTeam2 = 4;
            UnitCreate(1, "Bunker2", 0, 14, PointFromId(1320118314), 270.0);
            gv_team2Spawner1 = UnitLastCreated();
            UnitCreate(1, "Bunker2", 0, 14, RegionGetCenter(RegionFromId(14)), 270.0);
            gv_team2Spawner2 = UnitLastCreated();
            UnitCreate(1, "Bunker2", 0, 14, RegionGetCenter(RegionFromId(15)), 270.0);
            gv_team2Spawner3 = UnitLastCreated();
        }

        lv_raceCheck = gf_IsZerg(gv_rTSPlayer2);;
        if ((lv_raceCheck == true)) {
            gv_team2SpawnUnit = "Zergling2";
            gv_amountTeam2 = 6;
            UnitCreate(1, "NydusCanal2", 0, 14, PointFromId(1320118314), 270.0);
            gv_team2Spawner1 = UnitLastCreated();
            UnitCreate(1, "NydusCanal2", 0, 14, RegionGetCenter(RegionFromId(14)), 270.0);
            gv_team2Spawner2 = UnitLastCreated();
            UnitCreate(1, "NydusCanal2", 0, 14, RegionGetCenter(RegionFromId(15)), 270.0);
            gv_team2Spawner3 = UnitLastCreated();
        }

        lv_raceCheck = gf_IsNonKnownRace(gv_rTSPlayer2);;
        if ((lv_raceCheck == false)) {
            gv_team2SpawnUnit = "Zealot2";
            gv_amountTeam2 = 2;
            UnitCreate(1, "VoidPylon", 0, 14, PointFromId(1320118314), 270.0);
            gv_team2Spawner1 = UnitLastCreated();
            UnitCreate(1, "VoidPylon", 0, 14, RegionGetCenter(RegionFromId(14)), 270.0);
            gv_team2Spawner2 = UnitLastCreated();
            UnitCreate(1, "VoidPylon", 0, 14, RegionGetCenter(RegionFromId(15)), 270.0);
            gv_team2Spawner3 = UnitLastCreated();
        }

    }

    gf_SpawnJungle();
    return true;
}

