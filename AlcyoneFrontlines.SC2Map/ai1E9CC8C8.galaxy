//--------------------------------------------------------------------------------------------------
// Start
//--------------------------------------------------------------------------------------------------
bool ai1E9CC8C8_initialized = false;

//--------------------------------------------------------------------------------------------------
void ai1E9CC8C8_start (int p) {
    int init_i;

    if (p < 0 || p >= 16) {
        return;
    }
    if (!ai1E9CC8C8_initialized) {
        ai1E9CC8C8_wave1_init();
        ai1E9CC8C8_wave2_init();
        ai1E9CC8C8_wave3_init();
        ai1E9CC8C8_wave4_init();
        ai1E9CC8C8_wave5_init();
        ai1E9CC8C8_waves_init();

        for (init_i = 0; init_i <= 16; init_i += 1) {
            ai1E9CC8C8_defGather[init_i] = PointFromId(0);
        }

        ai1E9CC8C8_initialized = true;
    }

    AICampaignStart(p);
}
