//--------------------------------------------------------------------------------------------------
// Attack Wave Sequence
//--------------------------------------------------------------------------------------------------
trigger ai1E9CC8C8_waves_trigger = null;
int ai1E9CC8C8_waves_runPlayer;
playergroup ai1E9CC8C8_waves_runTarget;

//--------------------------------------------------------------------------------------------------
void ai1E9CC8C8_waves_init () {
    ai1E9CC8C8_waves_trigger = TriggerCreate("ai1E9CC8C8_waves_runFunc");
}

//--------------------------------------------------------------------------------------------------
bool ai1E9CC8C8_waves_runFunc (bool c, bool a) {
    int p = ai1E9CC8C8_waves_runPlayer;
    playergroup target = ai1E9CC8C8_waves_runTarget;

    if (p < 0 || p >= 16) {
        return false;
    }

    ai1E9CC8C8_wave1_run(p, target, true);
    ai1E9CC8C8_wave2_run(p, target, true);
    ai1E9CC8C8_wave3_run(p, target, true);
    ai1E9CC8C8_wave4_run(p, target, true);
    ai1E9CC8C8_wave5_run(p, target, true);

    return true;
}

//--------------------------------------------------------------------------------------------------
void ai1E9CC8C8_waves_run (int p, playergroup target) {
    ai1E9CC8C8_waves_runPlayer = p;
    ai1E9CC8C8_waves_runTarget = PlayerGroupCopy(target);

    TriggerExecute(ai1E9CC8C8_waves_trigger, false, false);
}

//--------------------------------------------------------------------------------------------------
void ai1E9CC8C8_waves_enable (int p, bool val) {
    if (p < 0 || p >= 16) {
        return;
    }

    ai1E9CC8C8_wave1_enable(p, val);
    ai1E9CC8C8_wave2_enable(p, val);
    ai1E9CC8C8_wave3_enable(p, val);
    ai1E9CC8C8_wave4_enable(p, val);
    ai1E9CC8C8_wave5_enable(p, val);
}

//--------------------------------------------------------------------------------------------------
void ai1E9CC8C8_waves_stop () {
    TriggerStop(ai1E9CC8C8_waves_trigger);

    TriggerStop(ai1E9CC8C8_wave1_trigger);
    TriggerStop(ai1E9CC8C8_wave2_trigger);
    TriggerStop(ai1E9CC8C8_wave3_trigger);
    TriggerStop(ai1E9CC8C8_wave4_trigger);
    TriggerStop(ai1E9CC8C8_wave5_trigger);
}

